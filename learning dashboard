<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LogicScale — Learning Progress Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --paper: #f2ede4;
  --ink: #1a1208;
  --ink2: #4a3f2f;
  --ink3: #9a8f7f;
  --rule: #d8d0c0;
  --red: #c0392b;
  --amber: #d35400;
  --gold: #c49a00;
  --green: #1a6b35;
  --blue: #1a3a6b;
  --teal: #0e6b5a;
  --surface: #faf6ef;
  --surface2: #f0ead8;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Crimson Pro', Georgia, serif;
  min-height: 100vh;
  position: relative;
}

/* Ruled paper background */
body::before {
  content:'';
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    repeating-linear-gradient(
      transparent,
      transparent 31px,
      rgba(26,18,8,0.07) 31px,
      rgba(26,18,8,0.07) 32px
    ),
    linear-gradient(90deg, transparent 59px, rgba(192,57,43,0.15) 59px, rgba(192,57,43,0.15) 61px, transparent 61px);
}

/* ── HEADER ── */
header {
  position: relative; z-index:10;
  border-bottom: 3px double var(--ink);
  padding: 2rem 2rem 1.5rem;
  background: var(--paper);
}
.header-top { display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:1rem; }
.header-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 6vw, 4rem);
  letter-spacing: .04em;
  line-height: 1;
  color: var(--ink);
}
.header-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: .65rem;
  color: var(--ink3);
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-top: .3rem;
}
.header-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: .65rem;
  padding: .3rem .75rem;
  border: 1.5px solid var(--ink);
  letter-spacing: .08em;
  background: var(--ink);
  color: var(--paper);
}

/* ── MAIN ── */
main {
  position: relative; z-index:1;
  max-width: 1100px; margin: 0 auto;
  padding: 2rem 2rem 4rem;
}

/* ── SECTION HEADING ── */
.sec-head {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.6rem;
  letter-spacing: .06em;
  color: var(--ink);
  border-bottom: 1.5px solid var(--ink);
  padding-bottom: .3rem;
  margin: 2.5rem 0 1.25rem;
  display: flex; align-items: baseline; gap: 1rem;
}
.sec-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: .7rem;
  color: var(--red);
  letter-spacing: .1em;
}

/* ── KPI ROW ── */
.kpi-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; margin-bottom: 1.5rem; }
@media(max-width:700px){ .kpi-row{grid-template-columns:repeat(2,1fr);} }
.kpi {
  background: var(--surface);
  border: 1.5px solid var(--ink);
  padding: 1rem 1.1rem;
  position: relative;
}
.kpi::before {
  content:'';
  position:absolute; top:4px; left:4px; right:-4px; bottom:-4px;
  border: 1.5px solid var(--ink); z-index:-1;
}
.kpi-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.5rem;
  line-height: 1;
  color: var(--ink);
}
.kpi-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: .58rem;
  color: var(--ink3);
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-top: .25rem;
}
.kpi-delta {
  font-family: 'JetBrains Mono', monospace;
  font-size: .65rem;
  margin-top: .2rem;
}
.up { color: var(--green); }
.dn { color: var(--red); }

/* ── CHART GRID ── */
.chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
@media(max-width:700px){ .chart-grid{grid-template-columns:1fr;} }
.chart-card {
  background: var(--surface);
  border: 1.5px solid var(--ink);
  overflow: hidden;
}
.chart-head {
  padding: .55rem 1rem;
  border-bottom: 1.5px solid var(--ink);
  font-family: 'JetBrains Mono', monospace;
  font-size: .62rem;
  letter-spacing: .08em;
  color: var(--ink2);
  text-transform: uppercase;
  background: var(--surface2);
  display: flex; justify-content:space-between; align-items:center;
}
.chart-body { padding: 1rem; }

/* ── LEARNING TIMELINE ── */
.timeline {
  position: relative;
  padding-left: 2rem;
}
.timeline::before {
  content:'';
  position:absolute; left:.7rem; top:0; bottom:0;
  width:2px; background: var(--rule);
}
.tl-item {
  position:relative; margin-bottom:1.25rem;
  animation: fadeUp .4s ease both;
}
.tl-dot {
  position:absolute; left:-1.65rem; top:.35rem;
  width:12px; height:12px; border-radius:50%;
  border:2px solid var(--ink);
  background: var(--paper);
}
.tl-version {
  font-family:'Bebas Neue',sans-serif; font-size:1rem;
  letter-spacing:.06em; color:var(--ink);
}
.tl-date {
  font-family:'JetBrains Mono',monospace; font-size:.6rem;
  color:var(--ink3); margin-left:.5rem;
}
.tl-desc {
  font-size:.85rem; color:var(--ink2); line-height:1.6;
  margin-top:.2rem;
}
.tl-metrics {
  display:flex; gap:.75rem; flex-wrap:wrap; margin-top:.4rem;
}
.tl-chip {
  font-family:'JetBrains Mono',monospace; font-size:.6rem;
  padding:.2rem .55rem; border:1px solid var(--rule);
  letter-spacing:.06em;
}
.chip-green { border-color:var(--green); color:var(--green); background:rgba(26,107,53,.06); }
.chip-red   { border-color:var(--red);   color:var(--red);   background:rgba(192,57,43,.06); }
.chip-blue  { border-color:var(--blue);  color:var(--blue);  background:rgba(26,58,107,.06); }

/* ── FINDING CARDS ── */
.findings-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
@media(max-width:700px){ .findings-grid{grid-template-columns:1fr;} }
.finding {
  border:1.5px solid var(--ink); padding:1rem 1.1rem;
  background:var(--surface); position:relative;
}
.finding-num {
  font-family:'Bebas Neue',sans-serif; font-size:3rem;
  line-height:1; color:var(--rule); position:absolute;
  right:.75rem; top:.25rem;
}
.finding-title {
  font-family:'Bebas Neue',sans-serif; font-size:1rem;
  letter-spacing:.05em; color:var(--ink); margin-bottom:.4rem;
}
.finding-body {
  font-size:.82rem; color:var(--ink2); line-height:1.65;
}
.finding-stat {
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  margin-top:.5rem; padding:.3rem .5rem;
  border-left:3px solid var(--red); background:rgba(192,57,43,.05);
  color:var(--red);
}

/* ── V4.2 CHANGES ── */
.changes-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.changes-table th {
  font-family:'JetBrains Mono',monospace; font-size:.6rem;
  letter-spacing:.08em; padding:.5rem .75rem;
  border-bottom:2px solid var(--ink); text-align:left;
  color:var(--ink3); text-transform:uppercase;
}
.changes-table td { padding:.55rem .75rem; border-bottom:1px solid var(--rule); }
.changes-table tr:hover td { background:var(--surface2); }
.badge {
  font-family:'JetBrains Mono',monospace; font-size:.58rem;
  padding:.12rem .4rem; letter-spacing:.05em;
}
.b-raised { background:rgba(211,84,0,.1); color:var(--amber); border:1px solid var(--amber); }
.b-new    { background:rgba(26,107,53,.1); color:var(--green); border:1px solid var(--green); }
.b-fixed  { background:rgba(26,58,107,.1); color:var(--blue);  border:1px solid var(--blue);  }

@keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
.animate { animation:fadeUp .5s ease both; }
</style>
</head>
