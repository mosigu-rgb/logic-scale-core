class IntuitionTranslator:
    """
    [R3] NEW in v4.1.
    Detects when an emotionally framed argument contains a strong
    underlying analytical insight that the speaker cannot articulate formally.
    Surfaces the 'academic version' of their own idea.
    """

    EMOTIONAL_MARKERS = [
        "unfair", "ungerecht", "ich muss", "warum sollen",
        "feel", "believe", "fühle", "finde das", "offensichtlich",
        "everyone knows", "jeder weiß", "das macht doch keinen sinn",
        "bringt nichts", "sowieso", "einfach", "halt"
    ]

    STRUCTURAL_CONCEPTS = {
        "unfair": "structural inequality / Verteilungsgerechtigkeit",
        "ungerecht": "structural inequality / distributive justice",
        "ich muss": "differential burden / unequal constraint",
        "warum sollen andere": "parity argument / equal treatment principle",
        "bringt nichts": "null hypothesis claim — requires evidence to support",
        "jeder weiß": "appeal to consensus — needs empirical backing",
    }

    @staticmethod
    def analyze(argument: str) -> dict:
        """
        Returns dict with:
          has_hidden_insight: bool
          emotional_intensity: float 0-1
          detected_concept: str or None
          translation_hint: str
        """
        text_lower = argument.lower()
        markers_found = [
            m for m in IntuitionTranslator.EMOTIONAL_MARKERS
            if m in text_lower
        ]
        emotional_intensity = min(1.0, len(markers_found) / 3)
        detected_concept = None
        for key, concept in IntuitionTranslator.STRUCTURAL_CONCEPTS.items():
            if key in text_lower:
                detected_concept = concept
                break

        has_hidden = emotional_intensity > 0.3 and len(argument.split()) > 20

        # Generate translation hint
        if "ungerecht" in text_lower or "unfair" in text_lower:
            hint = (
                "Your argument contains a structural equity claim. "
                "The academic form: 'Homeoffice availability correlates with income — "
                "56% of low-wage workers cannot access it (Destatis 2022), "
                "deepening existing inequality. Policy response: mobility allowances.' "
                "That is YOUR argument, stated formally."
            )
        elif "bringt nichts" in text_lower or "geht nicht" in text_lower:
            hint = (
                "Your argument implies: 'physical presence is required for my work, "
                "therefore it should be required for all.' "
                "The stronger version: 'Jobs requiring physical presence should receive "
                "equivalent benefits (mobility pay, reduced commute time) to remote-capable jobs.'"
            )
        else:
            hint = (
                f"I detect {len(markers_found)} emotional marker(s): {markers_found[:3]}. "
                "Try restating your core feeling as a falsifiable claim: "
                "'I believe X is true AND here is evidence that would prove it wrong if absent.'"
            )

        return {
            "has_hidden_insight":  has_hidden,
            "emotional_intensity": round(emotional_intensity, 2),
            "detected_concept":    detected_concept,
            "translation_hint":    hint,
            "markers_found":       markers_found,
        }


class AnalyzerV41:
    """
    LogicScale Neural Engine v4.1
    Upgraded from corpus research. Backward compatible with v4.0 output schema.
    """

    def __init__(self, settings: dict):
        self.settings = settings
        self.intuition = IntuitionTranslator()
        self._init_client()

    def _init_client(self):
        try:
            import anthropic
            self.client = anthropic.Anthropic(
                api_key=self.settings["anthropic_api_key"]
            )
        except ImportError:
            raise RuntimeError("pip install anthropic")

    def audit(
        self,
        argument: str,
        age:      int  = 17,
        skill:    str  = "intermediate",
        session:  int  = 1,
        region:   str  = "unknown",
        topic:    str  = "general",
        user_id:  str  = "anonymous",
    ) -> dict:

        tier      = vocab_tier(age)
        recency   = self._recency(session)
        expected  = SKILL_BASELINE.get(skill, 2.8)
        intuition = self.intuition.analyze(argument)

        system = self._system_prompt(tier, skill, expected, recency, session, intuition)
        user   = self._user_prompt(argument, age, skill, session, tier, intuition)

        raw    = self._call(system, user)
        result = self._parse(raw)

        # Inject metadata
        result.setdefault("neural_meta", {}).update({
            "engine_version":  "4.1.0",
            "user_age":        age,
            "skill_level":     skill,
            "vocabulary_tier": tier,
            "session_number":  session,
            "region":          region,
            "topic":           topic,
            "timestamp":       datetime.now(timezone.utc).isoformat(),
        })
        result["_raw_argument"]   = argument
        result["intuition_analysis"] = intuition

        # Safety net: recalculate scores locally
        result = self._validate(result, skill, session)
        return result

    # ── System prompt ──────────────────────────────────────────────────────────
    def _system_prompt(
        self, tier: str, skill: str, expected: float,
        recency: float, session: int, intuition: dict
    ) -> str:

        penalties_str = "\n".join(
            f"  {k:<42} {v:+.2f}" + (" ← [R2] RAISED from -0.50" if k == "hasty_generalization" else
                                       " ← [R4] NEW Expert Fallacy" if k in ("survivorship_bias_argument","scope_creep_fallacy","galaxy_brained_reasoning","moving_goalposts") else "")
            for k, v in PENALTIES.items()
        )
        bonuses_str = "\n".join(
            f"  {k:<42} {v:+.2f}" + (" ← [R1] NEW" if k == "formal_argument_structure" else "")
            for k, v in BONUSES.items()
        )
        corpus_str = "\n".join(
            f"  [{ex['score']:.2f}] \"{ex['argument'][:70]}\" → {ex['reason']}"
            for ex in CORPUS_EXAMPLES
        )
        vocab_rule = VOCAB_RULES[tier]

        intuition_block = ""
        if intuition.get("has_hidden_insight"):
            intuition_block = f"""
═══ INTUITION TRANSLATOR ACTIVE [R3] ═══
Pre-analysis detected STRONG HIDDEN INSIGHT in this argument:
  emotional_intensity: {intuition['emotional_intensity']}
  detected_concept:    {intuition.get('detected_concept','unknown')}
  translation_hint:    {intuition.get('translation_hint','')}

INSTRUCTION: In your coaching_output, ALWAYS include an "intuition_translation" field
that shows the user the academic version of their own argument.
Use phrasing: "Your core insight — stated formally — is: ..."
═══════════════════════════════════════
"""

        return f"""You are LogicScale Neural Engine v4.1 — upgraded from real-world corpus analysis.

{CORPUS_INSIGHT_SUMMARY}

REAL CORPUS EXAMPLES (few-shot memory):
{corpus_str}

═══ SCORING FORMULA v4.1 ═══
base = {SCORE_BASE}

BONUSES:
{bonuses_str}

PENALTIES (cumulative):
{penalties_str}

CLAMP final to [{SCORE_FLOOR}, {SCORE_CEILING}]
BE STRICT. 5.0 = near-perfect formal logic with external evidence. 3.0 = adequate but flawed.

═══ WEIGHT_DELTA ═══
expected_score for "{skill}" = {expected}
surprise_factor    = |{expected} - actual| / 5.0
recency_factor     = {recency} (session {session})
consistency_factor = 1.0 (1.5 if same fallacy appears repeatedly)
weight_delta       = CLAMP(surprise × recency × consistency, 0.01, 0.30)

═══ VOCABULARY — TIER: {tier.upper()} ═══
{vocab_rule}
THIS IS NON-NEGOTIABLE. Wrong vocabulary tier = system failure.
{intuition_block}
OUTPUT: VALID JSON ONLY. Zero text before or after."""

    # ── User prompt ────────────────────────────────────────────────────────────
    def _user_prompt(
        self, argument: str, age: int, skill: str,
        session: int, tier: str, intuition: dict
    ) -> str:

        intuition_field = ""
        if intuition.get("has_hidden_insight"):
            intuition_field = ',\n  "intuition_translation": "<academic restatement of the emotional argument — start with: Your core insight — stated formally — is:>"'

        return f"""ARGUMENT: "{argument}"
CONTEXT: age={age}, skill={skill}, session={session}, vocab_tier={tier}

Return ONLY this JSON:
{{
  "neural_meta": {{
    "engine_version": "4.1.0",
    "vocabulary_tier": "{tier}"
  }},
  "analysis": {{
    "logic_score": <float 0.0-5.0>,
    "score_breakdown": {{
      "base": {SCORE_BASE},
      "bonuses_applied": [{{"criterion": "<n>", "delta": <float>, "present": <bool>}}],
      "penalties_applied": [{{"criterion": "<fallacy>", "delta": <float>, "applied": <bool>}}],
      "raw_sum": <float>,
      "clamped_final": <float>
    }},
    "argument_quality": "<strong|adequate|weak|fallacious>",
    "fallacies": [{{
      "type": "<snake_case>",
      "latin_name": "<string|null>",
      "severity": "<low|medium|high|critical>",
      "confidence": <float>,
      "penalty_applied": <float>,
      "excerpt": "<exact phrase>",
      "explanation": "<{tier}-vocabulary explanation — enforce vocab tier strictly>",
      "fix": "<concrete actionable improvement>"
    }}],
    "cognitive_biases": [{{
      "type": "<bias_name>",
      "severity": "<mild|moderate|severe>",
      "note": "<{tier}-vocabulary note>"
    }}],
    "argument_style": "<narrative|analytical|data_driven|emotional|socratic>",
    "formal_training_signal": "<detected|not_detected>",
    "synthetic_twin": "<logically optimized rewrite — same position, no fallacies, add evidence>",
    "twin_improvements": ["<change1>","<change2>","<change3>"],
    "twin_score": <float>,
    "weight_delta": <float 0.01-0.30>,
    "weight_delta_breakdown": {{
      "surprise_factor": <float>,
      "recency_factor": <float>,
      "consistency_factor": <float>
    }}
  }},
  "coaching_output": {{
    "rebuttal": "<{tier}-vocabulary coaching rebuttal, 3-4 sentences>",
    "primary_tip": "<single most important improvement>",
    "drill_recommended": "<best next exercise for this profile>"{intuition_field}
  }},
  "engineering_note": "<1 sentence: why this score, referencing formula>"
}}"""

    # ── API ────────────────────────────────────────────────────────────────────
    def _call(self, system: str, user: str) -> str:
        resp = self.client.messages.create(
            model      = self.settings.get("model", "claude-sonnet-4-20250514"),
            max_tokens = self.settings.get("max_tokens", 2000),
            system     = system,
            messages   = [{"role": "user", "content": user}],
        )
        return resp.content[0].text

    # ── Parse ──────────────────────────────────────────────────────────────────
    def _parse(self, raw: str) -> dict:
        raw = re.sub(r'^```(?:json)?\s*', '', raw.strip())
        raw = re.sub(r'\s*```$', '', raw)
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            m = re.search(r'\{[\s\S]*\}', raw)
            if m:
                try:
                    return json.loads(m.group())
                except Exception:
                    pass
        return {
            "neural_meta": {"status": "parse_error"},
            "analysis": {
                "logic_score": 0.0, "argument_quality": "unknown",
                "fallacies": [], "weight_delta": 0.01,
            },
            "_parse_error": True,
        }

    # ── Validate ───────────────────────────────────────────────────────────────
    def _validate(self, result: dict, skill: str, session: int) -> dict:
        a  = result.get("analysis", {})
        ls = float(a.get("logic_score", SCORE_BASE))
        ls = max(SCORE_FLOOR, min(SCORE_CEILING, ls))
        a["logic_score"] = round(ls, 2)

        exp         = SKILL_BASELINE.get(skill, 2.8)
        recency     = self._recency(session)
        surprise    = abs(exp - ls) / 5.0
        consistency = float(
            a.get("weight_delta_breakdown", {}).get("consistency_factor", 1.0)
        )
        delta = max(0.01, min(0.30, surprise * recency * consistency))
        a["weight_delta"] = round(delta, 3)
        a.setdefault("weight_delta_breakdown", {}).update({
            "surprise_factor":    round(surprise, 3),
            "recency_factor":     round(recency, 2),
            "consistency_factor": round(consistency, 2),
        })

        # Quality label
        if ls >= 4.0:   a["argument_quality"] = "strong"
        elif ls >= 3.0: a["argument_quality"] = "adequate"
        elif ls >= 2.0: a["argument_quality"] = "weak"
        else:           a["argument_quality"] = "fallacious"

        result["analysis"] = a
        return result

    @staticmethod
    def _recency(session: int) -> float:
        if session <= 3:  return 0.80
        if session <= 10: return 1.00
        return 1.20


