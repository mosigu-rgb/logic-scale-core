<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DebateCoach — Argue Better</title>
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0e0e0e;
  --surface: #161616;
  --surface2: #1e1e1e;
  --border: #2a2a2a;
  --border2: #383838;
  --text: #f0ede8;
  --text2: #a0998e;
  --text3: #5a5550;
  --accent: #f5e642;
  --accent2: #ff5c2b;
  --green: #3ddc84;
  --red: #ff4757;
  --blue: #4da6ff;
  --purple: #c084fc;

  /* LITE MODE */
  --lite-bg: #fafaf8;
  --lite-surface: #ffffff;
  --lite-border: #e8e5e0;
  --lite-text: #1a1815;
  --lite-text2: #6b6560;
  --lite-accent: #e8a020;
  --lite-green: #16a34a;
  --lite-red: #dc2626;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background:var(--bg); color:var(--text);
  font-family:'Cabinet Grotesk',sans-serif;
  min-height:100vh; overflow-x:hidden;
}

/* ══ MODE TOGGLE ══ */
.mode-toggle {
  position:fixed; top:1rem; right:1rem; z-index:200;
  display:flex; align-items:center; gap:.5rem;
  background:var(--surface); border:1px solid var(--border2);
  padding:.4rem .75rem; border-radius:100px;
  font-family:'JetBrains Mono',monospace; font-size:.65rem;
  cursor:pointer; transition:all .3s; user-select:none;
}
.mode-toggle:hover { border-color:var(--accent); }
.toggle-pill {
  width:32px; height:18px; background:var(--border2);
  border-radius:9px; position:relative; transition:background .3s;
}
.toggle-ball {
  width:14px; height:14px; background:var(--text3);
  border-radius:50%; position:absolute; top:2px; left:2px;
  transition:all .3s;
}
.mode-toggle.lite .toggle-pill { background:var(--accent); }
.mode-toggle.lite .toggle-ball { left:16px; background:#fff; }

/* ══ LITE MODE OVERRIDES ══ */
body.lite {
  --bg: var(--lite-bg);
  --surface: var(--lite-surface);
  --surface2: #f3f1ec;
  --border: var(--lite-border);
  --border2: #d0ccc6;
  --text: var(--lite-text);
  --text2: var(--lite-text2);
  --text3: #9a9590;
  --accent: var(--lite-accent);
  --green: var(--lite-green);
  --red: var(--lite-red);
  --blue: #2563eb;
  --purple: #9333ea;
}
body.lite .mode-toggle { background:var(--lite-surface); border-color:var(--lite-border); color:var(--lite-text); }

/* ══ HERO ══ */
.hero {
  min-height:100vh; display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  padding:4rem 1.5rem 3rem; position:relative; overflow:hidden;
  text-align:center;
}

.hero-bg {
  position:absolute; inset:0; pointer-events:none;
  background:
    radial-gradient(ellipse 60% 50% at 30% 40%, rgba(245,230,66,.06) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 75% 60%, rgba(255,92,43,.05) 0%, transparent 60%);
  transition:opacity .5s;
}
body.lite .hero-bg { opacity:.4; }

/* Score meter ring */
.score-ring {
  width:120px; height:120px; margin:0 auto 1.5rem;
  position:relative; animation:ringIn .8s cubic-bezier(.175,.885,.32,1.275) both;
}
@keyframes ringIn { from{transform:scale(0) rotate(-90deg);opacity:0} to{transform:scale(1) rotate(0);opacity:1} }
.ring-svg { transform:rotate(-90deg); }
.ring-bg { fill:none; stroke:var(--border2); stroke-width:8; }
.ring-fill {
  fill:none; stroke:var(--accent); stroke-width:8;
  stroke-linecap:round;
  stroke-dasharray:283;
  stroke-dashoffset:283;
  animation:fillRing 1.5s ease .4s forwards;
  transition:stroke .3s;
}
@keyframes fillRing { to{stroke-dashoffset:66;} } /* 283*(1-0.77) */
.ring-text {
  position:absolute; inset:0; display:flex;
  flex-direction:column; align-items:center; justify-content:center;
}
.ring-score {
  font-family:'JetBrains Mono',monospace; font-size:1.6rem;
  font-weight:500; color:var(--accent); line-height:1;
}
.ring-label {
  font-family:'JetBrains Mono',monospace; font-size:.5rem;
  color:var(--text3); letter-spacing:.1em; margin-top:.15rem;
}

.hero-eyebrow {
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  color:var(--text3); letter-spacing:.15em; text-transform:uppercase;
  margin-bottom:1rem; animation:fadeUp .6s ease .1s both;
}
h1 {
  font-family:'Instrument Serif',serif;
  font-size:clamp(2.8rem,8vw,5.5rem);
  font-weight:400; line-height:1.1;
  margin-bottom:.75rem;
  animation:fadeUp .6s ease .2s both;
}
h1 em { font-style:italic; color:var(--accent); }
.hero-sub {
  font-size:1.05rem; color:var(--text2); line-height:1.65;
  max-width:480px; margin:0 auto 2.5rem;
  animation:fadeUp .6s ease .3s both;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

/* ══ CTA BUTTONS ══ */
.cta-row {
  display:flex; gap:.75rem; justify-content:center; flex-wrap:wrap;
  animation:fadeUp .6s ease .4s both;
}
.btn-primary {
  padding:.85rem 2rem; border:none; border-radius:12px;
  background:var(--accent); color:#0e0e0e;
  font-family:'Cabinet Grotesk',sans-serif; font-weight:800;
  font-size:1rem; cursor:pointer; transition:all .2s;
  display:flex; align-items:center; gap:.5rem;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(245,230,66,.25); }
.btn-secondary {
  padding:.85rem 2rem; border:1.5px solid var(--border2); border-radius:12px;
  background:transparent; color:var(--text);
  font-family:'Cabinet Grotesk',sans-serif; font-weight:700;
  font-size:1rem; cursor:pointer; transition:all .2s;
  display:flex; align-items:center; gap:.5rem;
}
.btn-secondary:hover { border-color:var(--text2); }

/* ══ LEARNING PROOF BAR ══ */
.proof-bar {
  display:flex; gap:2rem; justify-content:center; flex-wrap:wrap;
  margin-top:3rem; padding-top:2rem;
  border-top:1px solid var(--border);
  animation:fadeUp .6s ease .5s both;
}
.proof-stat { text-align:center; }
.proof-num {
  font-family:'JetBrains Mono',monospace; font-size:1.4rem;
  font-weight:500; color:var(--accent);
}
.proof-label {
  font-family:'JetBrains Mono',monospace; font-size:.58rem;
  color:var(--text3); letter-spacing:.1em; text-transform:uppercase;
  margin-top:.2rem;
}

/* ══ MAIN PRODUCT SECTION ══ */
.product-section {
  max-width:900px; margin:0 auto; padding:0 1.5rem 6rem;
}

.section-chip {
  display:inline-block; font-family:'JetBrains Mono',monospace;
  font-size:.65rem; padding:.25rem .7rem; border-radius:4px;
  letter-spacing:.08em; text-transform:uppercase;
  background:rgba(245,230,66,.1); color:var(--accent);
  border:1px solid rgba(245,230,66,.3); margin-bottom:1rem;
}

h2 {
  font-family:'Instrument Serif',serif; font-size:2.2rem;
  font-weight:400; line-height:1.2; margin-bottom:.5rem;
}
h2 em { font-style:italic; color:var(--accent); }
.section-sub { color:var(--text2); font-size:.95rem; margin-bottom:1.5rem; }

/* ══ ARGUMENT INPUT CARD ══ */
.input-card {
  background:var(--surface); border:1.5px solid var(--border2);
  border-radius:20px; overflow:hidden; margin-bottom:1rem;
  transition:border-color .3s;
}
.input-card:focus-within { border-color:var(--accent); }

.input-header {
  padding:.75rem 1.25rem;
  border-bottom:1px solid var(--border);
  background:var(--surface2);
  display:flex; align-items:center; justify-content:space-between;
}
.input-label {
  font-family:'JetBrains Mono',monospace; font-size:.65rem;
  color:var(--text3); letter-spacing:.08em; text-transform:uppercase;
}
.char-count {
  font-family:'JetBrains Mono',monospace; font-size:.62rem;
  color:var(--text3);
}

.arg-textarea {
  width:100%; padding:1.1rem 1.25rem;
  background:transparent; border:none;
  color:var(--text); font-family:'Cabinet Grotesk',sans-serif;
  font-size:1rem; line-height:1.65; resize:none;
  min-height:100px; outline:none;
}
.arg-textarea::placeholder { color:var(--text3); }

.input-footer {
  padding:.75rem 1.25rem;
  border-top:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  gap:.75rem; flex-wrap:wrap;
}
.config-mini { display:flex; gap:.5rem; flex-wrap:wrap; }
.mini-select {
  padding:.35rem .6rem; background:var(--surface2);
  border:1px solid var(--border2); border-radius:8px;
  color:var(--text2); font-family:'JetBrains Mono',monospace;
  font-size:.65rem; outline:none; cursor:pointer;
}
.mini-select:focus { border-color:var(--accent); color:var(--text); }

.analyze-btn {
  padding:.65rem 1.5rem; border:none; border-radius:10px;
  background:var(--accent); color:#0e0e0e;
  font-family:'Cabinet Grotesk',sans-serif; font-weight:800;
  font-size:.9rem; cursor:pointer; transition:all .2s;
  display:flex; align-items:center; gap:.4rem;
  white-space:nowrap;
}
.analyze-btn:hover { transform:translateY(-1px); box-shadow:0 4px 16px rgba(245,230,66,.2); }
.analyze-btn:disabled { opacity:.5; cursor:not-allowed; transform:none; }

/* ══ LOADING STATE ══ */
.loading-state {
  display:none; padding:2rem; text-align:center;
}
.loading-state.show { display:block; }
.loading-steps {
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  color:var(--text3); line-height:2;
}
.ls { opacity:.3; transition:opacity .2s; }
.ls.on { opacity:1; color:var(--accent); }
.ls.done { opacity:.6; color:var(--text2); }
.ls.done::before { content:'✓  '; color:var(--green); }
.loader-bar { height:2px; background:var(--border); border-radius:1px; overflow:hidden; margin:.75rem 0; }
.lb-fill { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); animation:lb 1.4s ease infinite; }
@keyframes lb { 0%{width:0;margin-left:0} 50%{width:55%;margin-left:22%} 100%{width:0;margin-left:100%} }

/* ══ RESULT CARD ══ */
.result-card {
  display:none; background:var(--surface);
  border:1.5px solid var(--border2); border-radius:20px;
  overflow:hidden; margin-top:1rem;
  animation:fadeUp .4s ease both;
}
.result-card.show { display:block; }

.result-header {
  padding:1.1rem 1.25rem;
  border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:.75rem;
}
.score-display { display:flex; align-items:baseline; gap:.4rem; }
.score-big {
  font-family:'JetBrains Mono',monospace; font-size:2.2rem;
  font-weight:500; line-height:1;
}
.score-max { font-family:'JetBrains Mono',monospace; font-size:.9rem; color:var(--text3); }
.quality-badge {
  padding:.3rem .75rem; border-radius:6px;
  font-family:'JetBrains Mono',monospace; font-size:.65rem;
  font-weight:500; letter-spacing:.06em;
}
.q-strong  { background:rgba(61,220,132,.15); color:var(--green); border:1px solid rgba(61,220,132,.3); }
.q-adequate{ background:rgba(245,230,66,.12); color:var(--accent); border:1px solid rgba(245,230,66,.25); }
.q-weak    { background:rgba(255,92,43,.12);  color:var(--accent2);border:1px solid rgba(255,92,43,.25); }
.q-fallacious{ background:rgba(255,71,87,.12);color:var(--red);   border:1px solid rgba(255,71,87,.25); }

.result-body { padding:1.25rem; }

/* Tabs */
.result-tabs {
  display:flex; gap:.25rem; margin-bottom:1.25rem;
  border-bottom:1px solid var(--border); padding-bottom:0;
}
.rtab {
  padding:.5rem 1rem; font-family:'JetBrains Mono',monospace;
  font-size:.65rem; letter-spacing:.06em; text-transform:uppercase;
  border:none; background:transparent; color:var(--text3);
  cursor:pointer; border-bottom:2px solid transparent;
  margin-bottom:-1px; transition:all .2s;
}
.rtab:hover { color:var(--text2); }
.rtab.active { color:var(--accent); border-bottom-color:var(--accent); }

.tab-panel { display:none; }
.tab-panel.active { display:block; }

/* Fallacy list */
.fallacy-list { display:flex; flex-direction:column; gap:.6rem; }
.fallacy-item {
  border:1px solid var(--border2); border-radius:12px; overflow:hidden;
}
.fi-head {
  padding:.6rem 1rem; display:flex; align-items:center;
  justify-content:space-between; cursor:pointer;
  transition:background .2s;
}
.fi-head:hover { background:var(--surface2); }
.fi-name { font-size:.82rem; font-weight:700; color:var(--accent2); }
.fi-badges { display:flex; gap:.35rem; }
.sev { padding:.12rem .4rem; border-radius:4px; font-family:'JetBrains Mono',monospace; font-size:.58rem; }
.s-low    { background:rgba(61,220,132,.12); color:var(--green); }
.s-medium { background:rgba(245,230,66,.12); color:var(--accent); }
.s-high   { background:rgba(255,92,43,.12);  color:var(--accent2); }
.s-crit   { background:rgba(255,71,87,.12);  color:var(--red); }
.fi-body { display:none; padding:.85rem 1rem; font-size:.85rem; color:var(--text2); line-height:1.65; border-top:1px solid var(--border); }
.fi-body.open { display:block; }
.fi-excerpt { border-left:2px solid var(--accent2); padding-left:.75rem; font-style:italic; margin:.4rem 0; font-size:.8rem; color:var(--text3); }
.fi-fix { margin-top:.5rem; padding:.5rem .75rem; background:rgba(61,220,132,.06); border:1px solid rgba(61,220,132,.2); border-radius:8px; font-size:.78rem; color:var(--green); }

/* ══ IMPROVED VERSION ══ */
.improved-box {
  background:linear-gradient(135deg,rgba(61,220,132,.06),rgba(61,220,132,.02));
  border:1.5px solid rgba(61,220,132,.25); border-radius:14px;
  padding:1.1rem 1.25rem; margin-bottom:1rem;
}
.improved-label {
  font-family:'JetBrains Mono',monospace; font-size:.62rem;
  color:var(--green); letter-spacing:.1em; text-transform:uppercase;
  margin-bottom:.6rem; display:flex; align-items:center; gap:.4rem;
}
.improved-text {
  font-size:.92rem; line-height:1.75; color:var(--text);
  font-style:italic;
}
.improved-score {
  margin-top:.75rem; font-family:'JetBrains Mono',monospace;
  font-size:.7rem; color:var(--green);
}

/* Upgrade steps */
.upgrade-steps { display:flex; flex-direction:column; gap:.5rem; }
.ustep {
  display:flex; gap:.75rem; align-items:flex-start;
  padding:.75rem .9rem; background:var(--surface2);
  border:1px solid var(--border); border-radius:10px;
}
.ustep-num {
  width:24px; height:24px; border-radius:6px;
  background:var(--accent); color:#0e0e0e;
  font-family:'JetBrains Mono',monospace; font-size:.7rem;
  font-weight:700; display:flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.ustep-text { font-size:.85rem; color:var(--text2); line-height:1.55; }

/* ══ INTUITION CARD ══ */
.intuition-card {
  background:linear-gradient(135deg,rgba(192,132,252,.08),rgba(77,166,255,.05));
  border:1.5px solid rgba(192,132,252,.25); border-radius:14px;
  padding:1.1rem 1.25rem; margin-bottom:1rem;
}
.intuition-label {
  font-family:'JetBrains Mono',monospace; font-size:.62rem;
  color:var(--purple); letter-spacing:.1em; text-transform:uppercase;
  margin-bottom:.6rem; display:flex; align-items:center; gap:.4rem;
}
.intuition-text { font-size:.88rem; color:var(--text2); line-height:1.7; }

/* ══ ACTION ROW ══ */
.action-row {
  display:flex; gap:.75rem; padding:1rem 1.25rem;
  border-top:1px solid var(--border); flex-wrap:wrap;
}
.act-btn {
  padding:.6rem 1.25rem; border-radius:10px;
  font-family:'Cabinet Grotesk',sans-serif; font-weight:700;
  font-size:.85rem; cursor:pointer; transition:all .2s;
  display:flex; align-items:center; gap:.4rem;
}
.act-primary {
  background:var(--accent); color:#0e0e0e; border:none; flex:1;
  justify-content:center;
}
.act-primary:hover { box-shadow:0 4px 16px rgba(245,230,66,.2); }
.act-secondary {
  background:transparent; color:var(--text2);
  border:1px solid var(--border2);
}
.act-secondary:hover { border-color:var(--text2); color:var(--text); }

/* ══ LITE MODE SCORE DISPLAY ══ */
body.lite .score-big { color:var(--lite-accent); }
body.lite .ring-fill { stroke:var(--lite-accent); }
body.lite .ring-score { color:var(--lite-accent); }
body.lite .analyze-btn { background:var(--lite-accent); }
body.lite .btn-primary { background:var(--lite-accent); }
body.lite .section-chip { background:rgba(232,160,32,.1); color:var(--lite-accent); border-color:rgba(232,160,32,.3); }
body.lite h1 em, body.lite h2 em { color:var(--lite-accent); }
body.lite .ustep-num { background:var(--lite-accent); }

/* ══ LITE MODE HERO ══ */
body.lite .hero { background:var(--lite-bg); }

/* ══ COMPARISON STRIP ══ */
.compare-strip {
  display:grid; grid-template-columns:1fr 1fr;
  gap:1rem; margin:1.5rem 0;
}
@media(max-width:600px){ .compare-strip{grid-template-columns:1fr;} }
.comp-box {
  background:var(--surface2); border:1px solid var(--border);
  border-radius:12px; padding:1rem;
}
.comp-label {
  font-family:'JetBrains Mono',monospace; font-size:.6rem;
  color:var(--text3); letter-spacing:.08em; text-transform:uppercase;
  margin-bottom:.5rem;
}
.comp-text { font-size:.85rem; color:var(--text2); line-height:1.6; }
.comp-score {
  font-family:'JetBrains Mono',monospace; font-size:.8rem;
  margin-top:.4rem;
}

/* ══ LEARNING GROWTH INDICATOR ══ */
.growth-bar-section { margin:2rem 0; }
.growth-row {
  display:flex; align-items:center; gap:.75rem;
  margin-bottom:.6rem;
}
.growth-label { font-family:'JetBrains Mono',monospace; font-size:.62rem; color:var(--text3); min-width:120px; }
.growth-track { flex:1; height:8px; background:var(--border2); border-radius:4px; overflow:hidden; }
.growth-fill { height:100%; border-radius:4px; transition:width 1.2s ease; }
.growth-val { font-family:'JetBrains Mono',monospace; font-size:.62rem; color:var(--text2); min-width:40px; text-align:right; }

/* ══ MISC ══ */
.empty-state {
  text-align:center; padding:3rem 1rem; color:var(--text3);
  font-family:'JetBrains Mono',monospace; font-size:.75rem; line-height:2;
}
.hidden { display:none !important; }
</style>
</head>
<body>

<!-- MODE TOGGLE -->
<div class="mode-toggle" id="modeToggle" onclick="toggleMode()">
  <span id="modeLabel" style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:inherit">PRO</span>
  <div class="toggle-pill"><div class="toggle-ball"></div></div>
  <span style="font-family:'JetBrains Mono',monospace;font-size:.62rem;color:inherit">LITE</span>
</div>

<!-- ══════════════════════════
  HERO
══════════════════════════ -->
<section class="hero" id="heroSection">
  <div class="hero-bg"></div>

  <div class="score-ring">
    <svg class="ring-svg" width="120" height="120" viewBox="0 0 120 120">
      <circle class="ring-bg" cx="60" cy="60" r="45"/>
      <circle class="ring-fill" id="heroRing" cx="60" cy="60" r="45"/>
    </svg>
    <div class="ring-text">
      <div class="ring-score" id="heroScore">2.97</div>
      <div class="ring-label">AVG/5.0</div>
    </div>
  </div>

  <div class="hero-eyebrow">150 arguments analyzed · v4.2 Neural Engine</div>
  <h1>Argue <em>smarter.</em><br>Not just harder.</h1>
  <p class="hero-sub">DebateCoach analyzes your argument, finds every logical flaw, and shows you the improved version — in seconds.</p>

  <div class="cta-row">
    <button class="btn-primary" onclick="scrollToTry()">
      ⚡ Try Your Argument
    </button>
    <button class="btn-secondary" onclick="scrollToLearning()">
      📊 How the Engine Learned
    </button>
  </div>

  <div class="proof-bar">
    <div class="proof-stat"><div class="proof-num">150</div><div class="proof-label">Args Analyzed</div></div>
    <div class="proof-stat"><div class="proof-num">12</div><div class="proof-label">Topics</div></div>
    <div class="proof-stat"><div class="proof-num">6×</div><div class="proof-label">System Updates</div></div>
    <div class="proof-stat"><div class="proof-num">19</div><div class="proof-label">Intuitions Found</div></div>
    <div class="proof-stat"><div class="proof-num">2</div><div class="proof-label">Languages</div></div>
  </div>
</section>

<!-- ══════════════════════════
  MAIN PRODUCT
══════════════════════════ -->
<section class="product-section" id="trySection">

  <div class="section-chip">⚡ Argument Analyzer</div>
  <h2>Test & <em>Improve</em> Your Argument</h2>
  <p class="section-sub" id="modeDescription">Pro Mode: Full analysis with fallacy taxonomy, weighted scoring, and academic references.</p>

  <!-- INPUT -->
