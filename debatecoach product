<script>
// ─────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────
let isLite = false;
let currentResult = null;
let isLoading = false;

const EXAMPLES = [
  { text:"Homeoffice steigert die Produktivität. Ich erledige Programmieraufgaben zuhause oft in der Hälfte der Zeit wie im Büro.", age:"24", skill:"intermediate", topic:"homeoffice" },
  { text:"Governments must act immediately on climate change. It's obvious that current policies are completely failing us.", age:"22", skill:"beginner", topic:"climate" },
  { text:"UBI simplifies welfare systems. Less bureaucracy means fewer administrative costs and more direct support for people who need it.", age:"29", skill:"advanced", topic:"ubi" },
  { text:"AI is just a tool. It's only dangerous if people misuse it, so there's no need for special regulation.", age:"26", skill:"intermediate", topic:"ki_alltag" },
];

// ─────────────────────────────────────────────────────
// MODE TOGGLE
// ─────────────────────────────────────────────────────
function toggleMode() {
  isLite = !isLite;
  document.body.classList.toggle('lite', isLite);
  document.getElementById('modeToggle').classList.toggle('lite', isLite);
  document.getElementById('modeLabel').textContent = isLite ? 'PRO' : 'PRO';
  document.getElementById('modeDescription').textContent = isLite
    ? 'Simple Mode: Plain feedback without technical jargon. Perfect for school and everyday use.'
    : 'Pro Mode: Full analysis with fallacy taxonomy, weighted scoring, and academic references.';
}

// ─────────────────────────────────────────────────────
// NAVIGATION
// ─────────────────────────────────────────────────────
function scrollToTry() {
  document.getElementById('trySection').scrollIntoView({behavior:'smooth'});
  setTimeout(()=>document.getElementById('argInput').focus(), 600);
}
function scrollToLearning() {
  document.getElementById('learningSection').scrollIntoView({behavior:'smooth'});
}

// ─────────────────────────────────────────────────────
// EXAMPLES
// ─────────────────────────────────────────────────────
function loadExample(i) {
  const ex = EXAMPLES[i];
  document.getElementById('argInput').value = ex.text;
  document.getElementById('cfgAge').value = ex.age;
  document.getElementById('cfgSkill').value = ex.skill;
  document.getElementById('cfgTopic').value = ex.topic;
  updateCharCount(document.getElementById('argInput'));
  document.getElementById('argInput').scrollIntoView({behavior:'smooth', block:'center'});
}

function updateCharCount(el) {
  document.getElementById('charCount').textContent = `${el.value.length} / 500`;
}

// ─────────────────────────────────────────────────────
// ANALYSIS
// ─────────────────────────────────────────────────────
async function runAnalysis() {
  const arg   = document.getElementById('argInput').value.trim();
  const age   = parseInt(document.getElementById('cfgAge').value);
  const skill = document.getElementById('cfgSkill').value;
  const topic = document.getElementById('cfgTopic').value;
  if (!arg || isLoading) return;

  isLoading = true;
  document.getElementById('analyzeBtn').disabled = true;
  document.getElementById('resultCard').classList.remove('show');
  document.getElementById('loadingState').classList.add('show');
  resetLoadingSteps();

  const [_, raw] = await Promise.all([
    animateSteps(),
    callEngine(arg, age, skill, topic)
  ]);

  document.getElementById('loadingState').classList.remove('show');

  let result = null;
  try {
    const m = raw.match(/\{[\s\S]*\}/);
    if (m) result = JSON.parse(m[0]);
  } catch(e) {}

  if (result) {
    currentResult = result;
    renderResult(result, arg);
  } else {
    document.getElementById('loadingState').classList.remove('show');
    alert('Analysis failed. Please check your API connection.');
  }

  isLoading = false;
  document.getElementById('analyzeBtn').disabled = false;
}

// ─────────────────────────────────────────────────────
// ENGINE CALL
// ─────────────────────────────────────────────────────
async function callEngine(arg, age, skill, topic) {
  const liteMode = isLite;
  const vocabTier = age < 14 ? 'elementary' : age < 18 ? 'secondary' : 'university';
  const expected = {beginner:2.0,intermediate:2.8,advanced:3.5,expert:4.2}[skill];

  const SYSTEM = `You are LogicScale Neural Engine v4.2. Built from 150 real argument corpus.

${liteMode ? `LITE MODE ACTIVE: Use simple, friendly language. No Latin terms. No academic jargon. 
Explain everything like you're talking to a student. Use short sentences. Be encouraging.` : 
`PRO MODE: Full academic vocabulary (age ${age}). Name fallacies formally. Cite real studies.`}

SCORING (0.0-5.0): base=2.5
Bonuses: empirical_evidence +1.0, clear_structure +0.75, anticipates_counterargument +0.5, nuanced_position +0.4, insider_evidence +0.35
Penalties: hasty_generalization -0.85, circular_reasoning -1.0, straw_man -1.0, false_dichotomy -0.75, motte_and_bailey -1.25, epistemic_cowardice -0.75, appeal_to_emotion_hard -0.65, appeal_to_emotion_soft -0.30, survivorship_bias -0.80, slippery_slope -0.5, appeal_to_popularity -0.5, vague_quantifier -0.35, anecdote_only -0.4, scope_creep -0.65
Clamp to [0.5, 5.0]

WEIGHT DELTA: surprise=|${expected}-actual|/5.0, clamp(surprise*recency*consistency, 0.01, 0.30)

INTUITION DETECTION: If emotional framing contains a valid underlying insight, mark has_hidden_insight:true and provide translation.

CRITICAL: Respond ONLY with valid JSON. No text outside JSON.`;

  const USER = `Argument: "${arg}"
Context: age=${age}, skill=${skill}, topic=${topic}, mode=${liteMode?'lite':'pro'}

Return ONLY this JSON:
{
  "logic_score": <0.0-5.0>,
  "argument_quality": "<strong|adequate|weak|fallacious>",
  "engineering_note": "<1 sentence why this score>",
  "fallacies": [{"type":"<name>","severity":"<low|medium|high|critical>","confidence":<0-1>,"excerpt":"<phrase>","explanation":"<explanation>","fix":"<fix>","latin_name":"<or null>","penalty":<negative float>}],
  "cognitive_biases": [{"type":"<name>","severity":"<mild|moderate|severe>","note":"<note>"}],
  "synthetic_twin": "<improved version — same position, no fallacies, add evidence>",
  "twin_improvements": ["<what changed 1>","<what changed 2>","<what changed 3>"],
  "twin_score": <float>,
  "intuition": {"has_hidden_insight":<bool>,"emotional_intensity":<0-1>,"concept":"<or null>","translation":"<formal version starting with 'Your core insight — stated formally: ...'>","data":"<relevant study or null>"},
  "coaching": {"primary_tip":"<most important fix>","upgrade_path":["<step1>","<step2>","<step3>"],"drill":"<specific exercise>"},
  "weight_delta": <0.01-0.30>,
  "score_breakdown": {"base":2.5,"bonuses":[{"criterion":"<n>","delta":<f>,"present":<bool>}],"penalties":[{"criterion":"<n>","delta":<f>,"applied":<bool>}]}
}`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:1500,
        system:SYSTEM, messages:[{role:'user',content:USER}]
      })
    });
    const data = await res.json();
    return data.content?.[0]?.text || '{}';
  } catch(e) { return '{"error":"'+e.message+'"}'; }
}

// ─────────────────────────────────────────────────────
// RENDER RESULT
// ─────────────────────────────────────────────────────
function renderResult(r, originalArg) {
  const score = r.logic_score || 0;
  const quality = r.argument_quality || 'unknown';

  // Header
  const scoreEl = document.getElementById('resScore');
  scoreEl.textContent = score.toFixed(2);
  scoreEl.style.color = scoreColor(score);

  const badge = document.getElementById('resBadge');
  badge.textContent = quality.toUpperCase();
  badge.className = 'quality-badge q-' + quality;

  document.getElementById('resNote').textContent = r.engineering_note || '';

  // Tab: Improved
  document.getElementById('origText').textContent = originalArg;
  document.getElementById('origScore').textContent = `Score: ${score.toFixed(2)}/5.0`;
  document.getElementById('improvedText').textContent = r.synthetic_twin || '—';
  document.getElementById('improvedScore').textContent = `Estimated score: ${r.twin_score || '?'}/5.0`;

  const improvEl = document.getElementById('twinImprovements');
  improvEl.innerHTML = (r.twin_improvements||[]).map(imp=>`
    <div style="display:flex;gap:.5rem;align-items:center;font-size:.8rem;color:var(--green);padding:.3rem 0">
      <span style="color:var(--green);flex-shrink:0">+</span>
      <span style="color:var(--text2)">${esc(imp)}</span>
    </div>`).join('');

  // Tab: Fallacies
  const fallacies = r.fallacies || [];
  const flEl = document.getElementById('fallacyList');
  if (fallacies.length === 0) {
    flEl.innerHTML = `<div class="empty-state">✓ No fallacies detected<br>Clean logical structure</div>`;
  } else {
    flEl.innerHTML = fallacies.map((f,i)=>`
      <div class="fallacy-item">
        <div class="fi-head" onclick="toggleFallacy(${i})">
          <span class="fi-name">${(f.type||'').replace(/_/g,' ').toUpperCase()}</span>
          <div class="fi-badges">
            <span class="sev s-${f.severity||'medium'}">${(f.severity||'').toUpperCase()}</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--red)">${f.penalty||''}</span>
          </div>
        </div>
        <div class="fi-body" id="fib${i}">
          ${f.latin_name?`<div style="font-size:.72rem;color:var(--purple);margin-bottom:.35rem;font-style:italic">Formally: ${f.latin_name}</div>`:''}
          ${f.excerpt?`<div class="fi-excerpt">"${esc(f.excerpt)}"</div>`:''}
          <div>${esc(f.explanation||'')}</div>
          ${f.fix?`<div class="fi-fix">✓ Fix: ${esc(f.fix)}</div>`:''}
        </div>
      </div>`).join('');
  }

  // Tab: Steps
  const steps = r.coaching?.upgrade_path || [];
  document.getElementById('upgradeSteps').innerHTML = steps.map((s,i)=>`
    <div class="ustep">
      <div class="ustep-num">${i+1}</div>
      <div class="ustep-text">${esc(s)}</div>
    </div>`).join('');
  document.getElementById('drillText').textContent = r.coaching?.drill || '—';

  // Tab: Intuition
  const intuit = r.intuition || {};
  if (intuit.has_hidden_insight) {
    document.getElementById('intuitionTab').style.display = 'block';
    document.getElementById('intuitionText').textContent = intuit.translation || '—';
    document.getElementById('intuitionData').textContent = intuit.data || '';
  } else {
    document.getElementById('intuitionTab').style.display = 'none';
  }

  // Tab: Raw JSON
  document.getElementById('rawJson').innerHTML = syntaxHL(JSON.stringify(r, null, 2));

  document.getElementById('resultCard').classList.add('show');
  document.getElementById('resultCard').scrollIntoView({behavior:'smooth', block:'start'});

  switchTab('improve');
}

function scoreColor(s) {
  if (s >= 4) return 'var(--green)';
  if (s >= 3) return 'var(--blue)';
  if (s >= 2) return 'var(--accent)';
  return 'var(--red)';
}

// ─────────────────────────────────────────────────────
// TABS
// ─────────────────────────────────────────────────────
function switchTab(id) {
  document.querySelectorAll('.rtab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}

function toggleFallacy(i) {
  document.getElementById('fib'+i).classList.toggle('open');
}

// ─────────────────────────────────────────────────────
// ACTIONS
// ─────────────────────────────────────────────────────
function tryImprovedVersion() {
  if (!currentResult?.synthetic_twin) return;
  document.getElementById('argInput').value = currentResult.synthetic_twin;
  updateCharCount(document.getElementById('argInput'));
  document.getElementById('resultCard').classList.remove('show');
  document.getElementById('argInput').scrollIntoView({behavior:'smooth', block:'center'});
}

function copyImproved() {
  const text = currentResult?.synthetic_twin || '';
  navigator.clipboard?.writeText(text).then(()=>{
    const btn = event.target;
    btn.textContent = '✓ Copied!';
    setTimeout(()=>btn.textContent='📋 Copy Improved', 2000);
  });
}

function resetResult() {
  document.getElementById('resultCard').classList.remove('show');
  document.getElementById('argInput').value = '';
  document.getElementById('charCount').textContent = '0 / 500';
  document.getElementById('argInput').focus();
}

// ─────────────────────────────────────────────────────
// LOADING ANIMATION
// ─────────────────────────────────────────────────────
function animateSteps() {
  return new Promise(resolve => {
    let i = 0;
    const tick = () => {
      if (i > 0) document.getElementById('ls'+(i-1)).className = 'ls done';
      if (i < 5) {
        document.getElementById('ls'+i).className = 'ls on';
        i++;
        setTimeout(tick, 350 + Math.random()*200);
      } else setTimeout(resolve, 200);
    };
    tick();
  });
}

function resetLoadingSteps() {
  for (let i=0;i<5;i++) document.getElementById('ls'+i).className='ls';
}

// ─────────────────────────────────────────────────────
// UTILS
// ─────────────────────────────────────────────────────
function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function syntaxHL(str) {
  const HL = ['logic_score','synthetic_twin','weight_delta','argument_quality'];
  return str.split('\n').map(line => {
    const h = HL.some(k=>line.includes(`"${k}"`));
    const c = line
      .replace(/("[\w_]+")\s*:/g,'<span style="color:#4da6ff">$1</span>:')
      .replace(/:\s*"([^"]*)"/g,': <span style="color:#fca5a5">"$1"</span>')
      .replace(/:\s*(-?\d+\.?\d*)/g,': <span style="color:#f5e642">$1</span>')
      .replace(/:\s*(true|false|null)/g,': <span style="color:#c084fc">$1</span>');
    return h
      ? `<span style="background:rgba(245,230,66,.1);border-left:2px solid #f5e642;padding-left:.3rem;display:block">${c}</span>`
      : `<span>${c}</span>`;
  }).join('\n');
}

// ─────────────────────────────────────────────────────
// GROWTH BAR ANIMATION
// ─────────────────────────────────────────────────────
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.growth-fill').forEach(bar => {
        bar.style.width = bar.dataset.w;
      });
    }
  });
}, {threshold:.3});

document.querySelectorAll('.growth-bar-section').forEach(el => observer.observe(el));
</script>
