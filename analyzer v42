# ANECDOTE DETECTOR v4.2 [R8]
# ══════════════════════════════════════════════════════════════════════════════

class AnecdoteDetector:
    """
    Distinguishes:
    - Pure anecdote: "Ich mache X" → weak personal claim
    - Insider evidence: "Als Pfleger sehe ich täglich X" → professional observation
    - Embedded data: "Laut Studie X..." → real evidence
    """

    INSIDER_ROLES = [
        "arzt","ärztin","pfleger","pflegerin","polizist","polizistin","lehrer",
        "lehrerin","jurist","anwalt","richter","ingenieur","pilot","feuerwehr",
        "sanitäter","krankenpfleger","doktor"
    ]
    DATA_SIGNALS = [
        "studie","studie zeigt","laut","prozent","%","forschung","daten","statistik",
        "analyse","bericht","erhebung","umfrage","research","according to","study"
    ]

    def classify(self, argument: str, job: str) -> dict:
        text = argument.lower()
        job_lower = job.lower()

        has_data     = any(s in text for s in self.DATA_SIGNALS)
        is_insider   = any(r in job_lower or r in text for r in self.INSIDER_ROLES)
        is_anecdote  = any(p in text for p in ["ich selbst","bei mir","ich persönlich",
                                                "meine erfahrung","in meinem fall"])

        if has_data:
            return {"type": "empirical", "bonus": "empirical_evidence", "penalty": None}
        elif is_insider and not is_anecdote:
            return {"type": "insider", "bonus": "insider_evidence", "penalty": None}
        elif is_anecdote:
            return {"type": "anecdote", "bonus": None, "penalty": "anecdote_only"}
        else:
            return {"type": "assertion", "bonus": None, "penalty": None}


