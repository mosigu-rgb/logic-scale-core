    "score_breakdown": {{
      "base": 2.5,
      "bonuses_applied": [{{"criterion":"<n>","delta":<f>,"present":<bool>}}],
      "penalties_applied": [{{"criterion":"<fallacy>","delta":<f>,"applied":<bool>}}],
      "raw_sum": <float>,
      "clamped_final": <float>
    }},
    "argument_quality": "<strong|adequate|weak|fallacious>",
    "fallacies": [{{
