class ProgressTracker:
    """Compares current argument to user's personal baseline."""

    def __init__(self, profile_db_path: Optional[Path] = None):
        self.db_path = profile_db_path

    def compare(self, user_id: str, current_score: float,
                current_fallacies: list) -> dict:
        """Returns comparison to personal baseline."""
        # If no profile DB, return basic feedback
        if not self.db_path or not self.db_path.exists():
            return {
                "has_history": False,
                "message": "Erstes Argument — Baseline wird gesetzt."
            }

        import sqlite3
        try:
            conn = sqlite3.connect(str(self.db_path))
            conn.row_factory = sqlite3.Row
            rows = conn.execute("""
                SELECT logic_score, primary_fallacy
                FROM argument_events
                WHERE user_id = ?
                ORDER BY timestamp DESC LIMIT 10
            """, (user_id,)).fetchall()
            conn.close()
        except Exception:
            return {"has_history": False, "message": "Keine Verlaufsdaten verfügbar."}

        if len(rows) < 2:
            return {
                "has_history": True,
                "session_count": len(rows),
                "message": "Noch zu wenig Daten für Vergleich. Weiter üben!"
            }

        scores     = [r["logic_score"] for r in rows]
        baseline   = sum(scores) / len(scores)
        delta      = current_score - baseline
        prev_falls = [r["primary_fallacy"] for r in rows if r["primary_fallacy"]]

        # Repeated fallacy detection
        repeated = []
        for f in current_fallacies:
            if prev_falls.count(f) >= 2:
                repeated.append(f)

        return {
            "has_history":       True,
            "session_count":     len(rows),
            "personal_baseline": round(baseline, 2),
            "current_score":     round(current_score, 2),
            "delta":             round(delta, 2),
            "trend":             "↑ besser" if delta > 0.1 else "↓ schlechter" if delta < -0.1 else "→ stabil",
            "repeated_fallacies": repeated,
            "message": (
                f"{'Verbesserung' if delta > 0 else 'Rückschritt'} von {delta:+.2f} "
                f"gegenüber deinem Durchschnitt ({baseline:.2f})."
                + (f" Wiederkehrender Fehler: {', '.join(repeated)}." if repeated else "")
            )
        }


