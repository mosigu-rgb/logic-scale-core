MANDATORY: Include "intuition_translation" in coaching_output.
Start with: "Deine Kernidee — formal ausgedrückt — ist: ..."
═════════════════════════════
"""
        anecdote_block = (
            f"\nEvidence type pre-classified: {anecdote['type']} "
            f"(bonus={anecdote['bonus']}, penalty={anecdote['penalty']})\n"
        )

        topic_info = TOPIC_DIFFICULTY.get(topic, TOPIC_DIFFICULTY["general"])
        corpus_note = (
            f"\nCORPUS CALIBRATION: Topic '{topic}' has avg score "
            f"{2.5 + topic_info['expected_bonus']:.1f} in 100-argument corpus. "
            f"Most common fallacy: {topic_info['common_fallacy']}.\n"
        )

        return f"""You are LogicScale Neural Engine v4.2.
Built from 100-argument German corpus (April 2026).
Corpus avg: 3.05/5.0 | Top fallacies: hasty_generalization (26%), appeal_to_emotion (21%)

USER: age={age}, job={job}, skill={skill}, topic={topic}, vocab_tier={tier}

