class IntuitionTranslatorV42:
    """[R3] Expanded to 13 patterns. Detects hidden analytical insights."""

    def analyze(self, argument: str, age: int, job: str, topic: str) -> dict:
        text = argument.lower()
        result = {
            "has_insight": False,
            "intensity": 0.0,
            "pattern": None,
            "concept": None,
            "translation": None,
            "data": None,
            "emotion_type": "hard",  # soft or hard
        }

        # Count emotional markers
        emotional_words = [
            "unfair","ungerecht","nervt","angst","fühle","finde","irgendwie",
            "halt","sowieso","einfach","echt","eigentlich","komisch","seltsam",
            "bequem","unangenehm","strange","honestly","I think","I feel","I believe"
        ]
        emotion_count = sum(1 for w in emotional_words if w in text)
        result["intensity"] = min(1.0, emotion_count / 3)

        # Pattern matching
        for pattern_name, pattern_data in INTUITION_PATTERNS.items():
            if any(trigger in text for trigger in pattern_data["triggers"]):
                result["has_insight"] = True
                result["pattern"]     = pattern_name
                result["concept"]     = pattern_data["concept"]
                result["data"]        = pattern_data["data"]
                # Fill template
                translation = pattern_data["translation"]
                translation = translation.replace("{pct}", "44")
                result["translation"] = translation
                break

        # Soft vs hard emotion classification
        # Soft: emotional framing but valid insight underneath
        # Hard: pure feeling with no translatable concept
        result["emotion_type"] = "soft" if result["has_insight"] else "hard"

        return result


