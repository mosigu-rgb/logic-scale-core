class AnalyzerV42:
    """LogicScale v4.2 — Full system with personalization and progress tracking."""

    def __init__(self, settings: dict):
        self.settings    = settings
        self.intuition   = IntuitionTranslatorV42()
        self.anecdote    = AnecdoteDetector()
        self.coach       = PersonalizedCoach()
        self.progress    = ProgressTracker()
        self._init_client()

    def _init_client(self):
        try:
            import anthropic
            self.client = anthropic.Anthropic(
                api_key=self.settings["anthropic_api_key"]
            )
        except ImportError:
            raise RuntimeError("pip install anthropic")

    def audit(
        self,
        argument:  str,
        age:       int  = 17,
        skill:     str  = "intermediate",
        session:   int  = 1,
        region:    str  = "unknown",
        topic:     str  = "general",
        user_id:   str  = "anonymous",
        job:       str  = "unknown",
    ) -> dict:

        tier       = vocab_tier(age)
        recency    = self._recency(session)
        expected   = SKILL_BASELINE.get(skill, 2.8)
        intuition  = self.intuition.analyze(argument, age, job, topic)
        anecdote   = self.anecdote.classify(argument, job)
        progress   = self.progress.compare(user_id, 0.0, [])  # pre-score

        system = self._build_system(tier, skill, expected, recency,
                                    session, intuition, anecdote, age, job, topic)
        user   = self._build_user(argument, age, skill, session, tier,
                                  intuition, anecdote, job, topic)

        raw    = self._call(system, user)
        result = self._parse(raw)
        result = self._validate(result, skill, session, topic)

        # Inject personalized coaching
        a         = result.get("analysis", {})
        score     = a.get("logic_score", 2.5)
        fallacies = [f["type"] for f in a.get("fallacies", [])]
        coaching  = self.coach.generate(score, fallacies, intuition,
                                        argument, age, job, topic)
        result["personalized_coaching"] = coaching
        result["intuition_analysis"]    = intuition
        result["anecdote_classification"] = anecdote
        result["progress"]              = progress

        # Metadata
        result.setdefault("neural_meta", {}).update({
            "engine_version": "4.2.0",
            "user_age": age, "skill_level": skill,
            "vocabulary_tier": tier, "session_number": session,
            "region": region, "topic": topic, "job": job,
            "timestamp": datetime.now(timezone.utc).isoformat(),
        })
        result["_raw_argument"] = argument
        return result

    def _build_system(self, tier, skill, expected, recency,
                      session, intuition, anecdote, age, job, topic) -> str:

        penalties_str = "\n".join(
            f"  {k:<45} {v:+.2f}" for k, v in PENALTIES.items()
        )
        bonuses_str = "\n".join(
            f"  {k:<45} {v:+.2f}" for k, v in BONUSES.items()
        )

        intuition_block = ""
        if intuition.get("has_insight"):
            intuition_block = f"""
