class PersonalizedCoach:
    """[R5] Generates age- and job-adapted coaching tips with relevant studies."""

    def generate(
        self, logic_score: float, fallacies: list,
        intuition: dict, argument: str,
        age: int, job: str, topic: str
    ) -> dict:

        age_group = "18-22" if age <= 22 else "23-27" if age <= 27 else "28+"
        style     = AGE_COMMUNICATION_STYLE[age_group]
        job_key   = self._map_job(job)

        # Pick relevant studies
        job_studies   = JOB_RELEVANT_STUDIES.get(job_key, JOB_RELEVANT_STUDIES["general"])
        topic_studies = TOPIC_STUDY_MAP.get(topic, [])
        relevant_study = topic_studies[0] if topic_studies else job_studies[0]

        # Primary tip
        if logic_score >= 4.0:
            primary_tip = self._tip_strong(age_group, relevant_study)
        elif logic_score >= 3.0:
            primary_tip = self._tip_adequate(fallacies, relevant_study, style)
        elif logic_score >= 2.0:
            primary_tip = self._tip_weak(fallacies, intuition, relevant_study, style)
        else:
            primary_tip = self._tip_fallacious(fallacies, style)

        # 3-step upgrade path [R10]
        upgrade_path = self._upgrade_path(logic_score, fallacies, intuition, relevant_study)

        # Drill recommendation
        drill = self._recommend_drill(fallacies, intuition, topic, job)

        return {
            "primary_tip":    primary_tip,
            "upgrade_path":   upgrade_path,
            "drill":          drill,
            "relevant_study": relevant_study,
            "age_group":      age_group,
            "communication_style": style["tone"],
        }

    def _tip_strong(self, age_group: str, study: str) -> str:
        return (
            f"Exzellentes Argument. Einzige Lücke: ein konkretes Zitat "
            f"würde es wasserdicht machen. Empfehlung: '{study}'"
        )

    def _tip_adequate(self, fallacies: list, study: str, style: dict) -> str:
        if fallacies:
            f = fallacies[0].replace("_"," ")
            return (
                f"Gute Grundstruktur. Der Hauptfehler ist {f}. "
                f"Ersetze dein Beispiel durch: '{study}' — "
                f"dann springst du von 'adequate' auf 'strong'."
            )
        return f"Solides Argument. Ergänze: '{study}' für maximale Überzeugungskraft."

    def _tip_weak(self, fallacies: list, intuition: dict, study: str, style: dict) -> str:
        if intuition.get("has_insight") and intuition.get("translation"):
            return (
                f"⭐ Du hast eine starke Kernidee — aber sie ist emotional formuliert. "
                f"Die analytische Version: {intuition['translation'][:200]}..."
            )
        if fallacies:
            f = fallacies[0].replace("_"," ")
            return (
                f"Das Argument enthält {f}. Beginne neu mit: "
                f"'[These] + [Warum gilt das allgemein, nicht nur für mich?] + [{study}]'"
            )
        return f"Füge externe Evidenz hinzu: '{study}'"

    def _tip_fallacious(self, fallacies: list, style: dict) -> str:
        if "circular_reasoning" in fallacies:
            return (
                "Der Grund und die Schlussfolgerung sind dasselbe. "
                "Frage dich: 'Was ist mein Grund — der NICHT mein Fazit wiederholt?' "
                "Schreibe diesen Grund auf, bevor du weitermachst."
            )
        return (
            "Das Argument enthält grundlegende logische Fehler. "
            "Starte mit: 'Ich behaupte X, weil Y — und Y ist wahr laut Z.'"
        )

    def _upgrade_path(
        self, score: float, fallacies: list,
        intuition: dict, study: str
    ) -> List[str]:
        steps = []
        if score < 2.0:
            steps = [
                "1. Finde EINEN unabhängigen Grund der deine These stützt (nicht sie wiederholt)",
                "2. Prüfe: 'Könnte jemand meinen Grund akzeptieren aber meine These trotzdem ablehnen?' Wenn ja, ist dein Grund stark.",
                f"3. Füge hinzu: '{study}'"
            ]
        elif score < 3.0:
            if intuition.get("has_insight"):
                steps = [
                    f"1. Formuliere deine Kernidee formal: '{intuition.get('concept','deine Intuition')}'",
                    f"2. Belege sie: '{intuition.get('data', study)}'",
                    "3. Antizipiere das stärkste Gegenargument in einem Satz"
                ]
            else:
                steps = [
                    "1. Ersetze dein persönliches Beispiel durch einen allgemeinen Beleg",
                    f"2. Nutze: '{study}'",
                    "3. Füge einen Satz hinzu der das stärkste Gegenargument nennt und widerlegt"
                ]
        elif score < 4.0:
            steps = [
                f"1. Füge ein Zitat ein: '{study}'",
                "2. Antizipiere das stärkste Gegenargument explizit",
                "3. Beende mit einer Policy-Empfehlung: Was genau soll sich ändern?"
            ]
        else:
            steps = [
                "1. Nenne den konkreten Mechanismus (nicht nur die Richtung)",
                f"2. Belege präziser: '{study}'",
                "3. Antwort auf: 'Welche Bedingung würde deine These falsifizieren?'"
            ]
        return steps

    def _recommend_drill(
        self, fallacies: list, intuition: dict, topic: str, job: str
    ) -> str:
        if "hasty_generalization" in fallacies:
            return "Evidence Drill: Schreibe das gleiche Argument neu — ohne 'ich', 'bei mir', 'mein'. Verwende nur externe Quellen."
        if "appeal_to_emotion_hard" in fallacies or "appeal_to_emotion" in fallacies:
            if intuition.get("has_insight"):
                return "Intuition-to-Argument Drill: Schreibe deine Emotion als Hypothese: 'Ich glaube X, weil Y. Wenn Y wahr ist, dann...' Suche dann Daten für Y."
            return "Claim-Evidence Drill: Für jeden Satz mit 'ich finde/fühle/glaube' schreibe eine Version ohne erste Person."
        if "circular_reasoning" in fallacies:
            return "Grund-Drill: Schreibe 3 Gründe für deine These die alle anders sind als die These selbst."
        if "epistemic_cowardice" in fallacies:
            return "Falsifiability Drill: Schreibe auf was dich dazu bringen würde, deine Meinung zu ändern. Dann verteidige deine These gegen genau das."
        if "false_dichotomy" in fallacies:
            return "Spektrum-Drill: Liste 5 Positionen zwischen deinen zwei Extremen auf. Wähle die stärkste und verteidige sie."
        if intuition.get("has_insight"):
            return f"Übersetzungs-Drill: Schreibe dein Argument ohne Emotionswörter um. Überprüfe: Ist es immer noch überzeugend?"
        return "Structure Drill: These (1 Satz) → Begründung (warum gilt das allgemein?) → Beleg (externe Quelle) → Gegenargument (1 Satz) → Widerlegung (1 Satz)."

    @staticmethod
    def _map_job(job: str) -> str:
        job_lower = job.lower()
        mapping = {
            "healthcare":   ["arzt","ärztin","pfleger","sanitäter","medizin","krankenhaus"],
            "technology":   ["entwickler","programmer","software","it","tech","informatik"],
            "law":          ["anwalt","jurist","richter","rechtsanwalt","jura"],
            "education":    ["lehrer","lehrerin","dozent","professor","pädagog","bildung"],
            "construction": ["bauarbeiter","handwerker","maurer","zimmermann","bau"],
            "retail":       ["verkäufer","einzelhandel","laden","shop","kassier"],
        }
        for key, keywords in mapping.items():
            if any(k in job_lower for k in keywords):
                return key
        return "general"


