# ── Compute aggregate stats ────────────────────────────────────────────────────
def compute_stats(corpus):
    scores = [a["score"] for a in corpus]
    fallacy_counts = {}
    intuition_count = 0
    strong_count = 0
    quality_dist = {}
    topic_scores = {}
    age_scores = {}

    for a in corpus:
        for f in a.get("fallacies", []):
            fallacy_counts[f] = fallacy_counts.get(f, 0) + 1
        if a.get("intuition"):
            intuition_count += 1
        q = a.get("quality","?")
        quality_dist[q] = quality_dist.get(q, 0) + 1
        topic = a.get("topic","?")
        if topic not in topic_scores:
            topic_scores[topic] = []
        topic_scores[topic].append(a["score"])
        age = a.get("age", 0)
        ag = "18-22" if age <= 22 else "23-27" if age <= 27 else "28+"
        if ag not in age_scores:
            age_scores[ag] = []
        age_scores[ag].append(a["score"])

    return {
        "total": len(corpus),
        "avg_score": round(sum(scores)/len(scores), 3),
        "min_score": min(scores),
        "max_score": max(scores),
        "quality_distribution": quality_dist,
        "fallacy_frequency": sorted(fallacy_counts.items(), key=lambda x: -x[1]),
        "intuition_detected": intuition_count,
        "topic_avg": {t: round(sum(v)/len(v),2) for t,v in topic_scores.items()},
        "age_group_avg": {ag: round(sum(v)/len(v),2) for ag,v in age_scores.items()},
    }

stats = compute_stats(CORPUS)

