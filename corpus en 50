# ── Compute stats ──────────────────────────────────────────────────────────────
def compute(corpus):
    scores = [a["score"] for a in corpus]
    fallacy_freq = {}
    quality_dist = {}
    topic_scores = {}
    age_scores   = {}
    intuition_ct = sum(1 for a in corpus if a.get("intuition"))

    for a in corpus:
        for f in a.get("fallacies",[]):
            fallacy_freq[f] = fallacy_freq.get(f,0)+1
        q = a.get("quality","?")
        quality_dist[q] = quality_dist.get(q,0)+1
        t = a.get("topic","?")
        topic_scores.setdefault(t,[]).append(a["score"])
        age = a.get("age",0)
        ag = "18-22" if age<=22 else "23-27" if age<=27 else "28+"
        age_scores.setdefault(ag,[]).append(a["score"])

    return {
        "total":             len(corpus),
        "avg_score":         round(sum(scores)/len(scores),3),
        "min_score":         min(scores),
        "max_score":         max(scores),
        "quality_dist":      dict(sorted(quality_dist.items(),key=lambda x:-x[1])),
        "fallacy_freq":      sorted(fallacy_freq.items(),key=lambda x:-x[1]),
        "intuition_detected":intuition_ct,
        "topic_avg":         {t:round(sum(v)/len(v),2) for t,v in topic_scores.items()},
        "age_avg":           {ag:round(sum(v)/len(v),2) for ag,v in age_scores.items()},
    }

stats = compute(CORPUS_EN)
Path("data").mkdir(exist_ok=True)
with open("data/corpus_en_50.json","w") as f:
