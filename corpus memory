class CorpusMemory:
    """
    Persistent knowledge base. Stores scored arguments, tracks fallacy
    prevalence, updates penalty calibration recommendations.
    """

    def __init__(self, db_path: Path = CORPUS_DB):
        db_path.parent.mkdir(parents=True, exist_ok=True)
        self.path = str(db_path)
        self._init()
        self._seed_founding_corpus()

    def _conn(self):
        conn = sqlite3.connect(self.path, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        return conn

    def _init(self):
        with self._conn() as conn:
            conn.executescript("""
            CREATE TABLE IF NOT EXISTS corpus (
                corpus_id       TEXT PRIMARY KEY,
                source          TEXT,
                profile         TEXT,
                age             INTEGER,
                skill           TEXT,
                job             TEXT,
                region          TEXT,
                topic           TEXT,
                argument_text   TEXT,
                logic_score     REAL,
                argument_quality TEXT,
                primary_fallacy TEXT,
                secondary_fallacy TEXT,
                argument_style  TEXT,
                bonuses_json    TEXT,
                penalties_json  TEXT,
                engineering_note TEXT,
                research_insight TEXT,
                intuition_strength TEXT,
                added_at        TEXT
            );

            CREATE TABLE IF NOT EXISTS penalty_calibration (
                fallacy_type    TEXT PRIMARY KEY,
                base_penalty    REAL,
                current_penalty REAL,
                corpus_count    INTEGER,
                corpus_pct      REAL,
                last_updated    TEXT,
                recommendation  TEXT
            );

            CREATE TABLE IF NOT EXISTS live_arguments (
                id              INTEGER PRIMARY KEY AUTOINCREMENT,
                added_at        TEXT,
                age             INTEGER,
                skill           TEXT,
                region          TEXT,
                topic           TEXT,
                argument_text   TEXT,
                logic_score     REAL,
                primary_fallacy TEXT,
                argument_style  TEXT
            );

            CREATE INDEX IF NOT EXISTS idx_corpus_fallacy ON corpus(primary_fallacy);
            CREATE INDEX IF NOT EXISTS idx_corpus_score   ON corpus(logic_score);
            CREATE INDEX IF NOT EXISTS idx_live_fallacy   ON live_arguments(primary_fallacy);
            """)

    def _seed_founding_corpus(self):
        """Insert the 10 founding arguments if not already present."""
        with self._conn() as conn:
            existing = conn.execute(
                "SELECT COUNT(*) FROM corpus WHERE source='batch_research_april_2026'"
            ).fetchone()[0]
            if existing >= 10:
                return

            for arg in FOUNDING_CORPUS:
                try:
                    conn.execute("""
                        INSERT OR IGNORE INTO corpus
                        (corpus_id, source, profile, age, skill, job, region, topic,
                         argument_text, logic_score, argument_quality, primary_fallacy,
                         secondary_fallacy, argument_style, bonuses_json, penalties_json,
                         engineering_note, research_insight, intuition_strength, added_at)
                        VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
                    """, (
                        arg["corpus_id"], arg["source"], arg["profile"],
                        arg["age"], arg["skill"], arg.get("job",""),
                        arg.get("region",""), arg.get("topic",""),
                        arg["argument"], arg["logic_score"],
                        arg["argument_quality"], arg.get("primary_fallacy"),
                        arg.get("secondary_fallacy"), arg.get("argument_style"),
                        json.dumps(arg.get("bonuses",[])),
                        json.dumps(arg.get("penalties",[])),
                        arg.get("engineering_note",""),
                        arg.get("research_insight",""),
                        arg.get("intuition_strength",""),
                        datetime.now(timezone.utc).isoformat(),
                    ))
                except Exception as e:
                    pass

        self._update_calibration()

    def add_live_argument(self, age: int, skill: str, region: str,
                          topic: str, argument: str, logic_score: float,
                          primary_fallacy: Optional[str],
                          argument_style: str) -> int:
        """Add a new live argument to memory. Triggers recalibration."""
        with self._conn() as conn:
            cur = conn.execute("""
                INSERT INTO live_arguments
                (added_at, age, skill, region, topic, argument_text,
                 logic_score, primary_fallacy, argument_style)
                VALUES(?,?,?,?,?,?,?,?,?)
            """, (
                datetime.now(timezone.utc).isoformat(),
                age, skill, region, topic, argument[:500],
                logic_score, primary_fallacy, argument_style,
            ))
            row_id = cur.lastrowid

        # Recalibrate every 10 new arguments
        total = self._total_live()
        if total % 10 == 0:
            self._update_calibration()

        return row_id

    def _total_live(self) -> int:
        with self._conn() as conn:
            return conn.execute(
                "SELECT COUNT(*) FROM live_arguments"
            ).fetchone()[0]

    def _update_calibration(self):
        """
        Recompute fallacy prevalence and generate penalty recommendations.
        If a fallacy appears in >25% of arguments, flag for penalty increase.
        """
        with self._conn() as conn:
            # Count from both corpus and live
            rows = conn.execute("""
                SELECT primary_fallacy, COUNT(*) as cnt
                FROM (
                    SELECT primary_fallacy FROM corpus WHERE primary_fallacy IS NOT NULL
                    UNION ALL
                    SELECT primary_fallacy FROM live_arguments WHERE primary_fallacy IS NOT NULL
                )
                GROUP BY primary_fallacy ORDER BY cnt DESC
            """).fetchall()

            total = sum(r["cnt"] for r in rows)
            if total == 0:
                return

            from analyzer_v41 import PENALTIES as BASE_PENALTIES

            for row in rows:
                fallacy = row["primary_fallacy"]
                cnt     = row["cnt"]
                pct     = round(cnt / total * 100, 1)
                base    = BASE_PENALTIES.get(fallacy, -0.50)

                # Recommendation logic
                if pct >= 25:
                    rec = f"HIGH PREVALENCE ({pct}%) — consider raising penalty by 0.25"
                    current = base - 0.25
                elif pct >= 15:
                    rec = f"MODERATE PREVALENCE ({pct}%) — penalty well-calibrated"
                    current = base
                else:
                    rec = f"LOW PREVALENCE ({pct}%) — penalty may be slightly high"
                    current = base

                conn.execute("""
                    INSERT INTO penalty_calibration
                    (fallacy_type, base_penalty, current_penalty, corpus_count,
                     corpus_pct, last_updated, recommendation)
                    VALUES(?,?,?,?,?,?,?)
                    ON CONFLICT(fallacy_type) DO UPDATE SET
                        current_penalty=excluded.current_penalty,
                        corpus_count=excluded.corpus_count,
                        corpus_pct=excluded.corpus_pct,
                        last_updated=excluded.last_updated,
                        recommendation=excluded.recommendation
                """, (
                    fallacy, base, current, cnt, pct,
                    datetime.now(timezone.utc).isoformat(), rec,
                ))

    def get_calibration_report(self) -> List[Dict]:
        with self._conn() as conn:
            rows = conn.execute("""
                SELECT * FROM penalty_calibration
                ORDER BY corpus_pct DESC
            """).fetchall()
        return [dict(r) for r in rows]

    def get_similar(self, logic_score: float, fallacy: Optional[str] = None,
                    n: int = 3) -> List[Dict]:
        """Find similar corpus examples for few-shot anchoring."""
        with self._conn() as conn:
            if fallacy:
                rows = conn.execute("""
                    SELECT * FROM corpus
                    WHERE primary_fallacy = ?
                    ORDER BY ABS(logic_score - ?) ASC LIMIT ?
                """, (fallacy, logic_score, n)).fetchall()
            else:
                rows = conn.execute("""
                    SELECT * FROM corpus
                    ORDER BY ABS(logic_score - ?) ASC LIMIT ?
                """, (logic_score, n)).fetchall()
        return [dict(r) for r in rows]

    def summary(self) -> Dict:
        with self._conn() as conn:
            overview = conn.execute("""
                SELECT COUNT(*) as total,
                       AVG(logic_score) as avg_score,
                       MIN(logic_score) as min_score,
                       MAX(logic_score) as max_score
                FROM corpus
            """).fetchone()
            top_fallacy = conn.execute("""
                SELECT primary_fallacy, COUNT(*) as cnt
                FROM corpus WHERE primary_fallacy IS NOT NULL
                GROUP BY primary_fallacy ORDER BY cnt DESC LIMIT 1
            """).fetchone()
            live_total = self._total_live()

        return {
            "founding_corpus":      10,
            "live_arguments":       live_total,
            "total_memory":         dict(overview)["total"] + live_total,
            "corpus_avg_score":     round(dict(overview)["avg_score"] or 0, 3),
            "corpus_min":           dict(overview)["min_score"],
            "corpus_max":           dict(overview)["max_score"],
            "top_fallacy":          dict(top_fallacy)["primary_fallacy"] if top_fallacy else "none",
            "calibration_updated":  True,
        }


