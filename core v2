    user_id  = args.user_id
    profile  = profile_db.get_or_create(user_id)
    insights = profile_db.personal_insights(user_id)

    print(f"\n⬡  Profile: {profile['display_name']} ({user_id})")
    print(f"   Rank: {profile['rank']}  XP: {profile['xp']}")
    print(f"   Sessions: {profile['total_sessions']}  Arguments: {profile['total_arguments']}")
    print(f"   Skill: {profile['skill_level']}  Age: {profile['age']}")

    cog = profile.get("cognitive", {})
    print(f"\n   Cognitive Fingerprint:")
    print(f"   • Dominant fallacy:   {cog.get('dominant_fallacy','none')}")
    print(f"   • Improvement rate:   {cog.get('improvement_velocity',0):+.4f}/session")
    print(f"   • Argument style:     {cog.get('argument_style','unknown')}")
    print(f"   • Consistency:        {cog.get('consistency_score',0):.2f}/1.0")
    print(f"   • Pressure resist.:   {cog.get('pressure_resistance',0):.2f}/1.0")

    if insights:
        print(f"\n   Personal Insights:")
        for i in insights:
            print(f"   → {i}")

    if args.curriculum:
        plan = profile_db.generate_curriculum(user_id)
        print(f"\n   30-Day Curriculum:")
        for week in plan:
            print(f"\n   Week {week['week']}: {week['focus']}")
            print(f"   Goal: {week['goal']}")
            for ex in week['exercises']:
                print(f"   • {ex}")


def _cmd_stats(audit_db, profile_db, cache):
    try:
        from rich.console import Console
        from rich.table   import Table
        console = Console()
    except ImportError:
        ana = Analytics(audit_db)
        print(json.dumps(ana.full_report(), indent=2, default=str))
        return

    console = Console()
    ana     = Analytics(audit_db)
    report  = ana.full_report()
    ov      = report.get("overview", {})

    console.print("\n[bold green]⬡ LogicScale Analytics[/bold green]\n")
    console.print(f"  Total audits:        [bold]{ov.get('total_audits',0)}[/bold]")
    console.print(f"  Avg logic_score:     [yellow]{ov.get('avg_logic_score',0):.2f}[/yellow]/5.0")
    console.print(f"  Top fallacy:         [red]{ov.get('top_fallacy','—')}[/red]")
    console.print(f"  Unique regions:      [cyan]{ov.get('unique_regions',0)}[/cyan]")

    cache_s = cache.stats()
    console.print(f"  Cache hits:          [dim]{cache_s.get('total_hits',0)}[/dim]")

    region_data = report.get("by_region",[])
    if region_data:
        t = Table(title="By Region", border_style="blue")
        t.add_column("Region"); t.add_column("Audits"); t.add_column("Avg Score"); t.add_column("Top Fallacy")
        for r in region_data[:10]:
            t.add_row(r["region"], str(r["count"]),
                      f"{r['avg_score']:.2f}", r.get("top_fallacy","—"))
        console.print(t)


