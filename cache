"""
LogicScale Neural Engine v4.0
cache.py — Two things:
  1. Argument cache: identical arguments → return cached result (saves API cost)
  2. Rate limiter: max N requests per user per minute
"""

import json
import time
import hashlib
import sqlite3
from datetime import datetime, timezone
from pathlib  import Path
from typing   import Optional

CACHE_DB = Path(__file__).parent / "data" / "cache.db"


class ArgumentCache:
    """
    Content-addressed cache for analysis results.
    Key: SHA256(argument_text + skill_level + age_bucket)
    TTL: 24 hours (arguments don't change meaning)
    """

    def __init__(self, db_path: Path = CACHE_DB, ttl_hours: int = 24):
        db_path.parent.mkdir(parents=True, exist_ok=True)
        self.path     = str(db_path)
        self.ttl_hours = ttl_hours
        self._init()

    def _conn(self):
        conn = sqlite3.connect(self.path, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        conn.execute("PRAGMA journal_mode=WAL")
        return conn

    def _init(self):
        with self._conn() as conn:
            conn.executescript("""
            CREATE TABLE IF NOT EXISTS cache (
                cache_key    TEXT PRIMARY KEY,
                result_json  TEXT,
                created_at   TEXT,
                hits         INTEGER DEFAULT 0
            );
            CREATE TABLE IF NOT EXISTS rate_limits (
                user_id      TEXT,
                window_start TEXT,
                count        INTEGER DEFAULT 0,
                PRIMARY KEY (user_id, window_start)
            );
            """)

    @staticmethod
    def _make_key(argument: str, skill: str, age: int) -> str:
        # Normalize: strip whitespace, lowercase, bucket age to ±2 years
        age_bucket = (age // 4) * 4
        raw = f"{argument.strip().lower()}|{skill}|{age_bucket}"
        return hashlib.sha256(raw.encode()).hexdigest()

    def get(self, argument: str, skill: str, age: int) -> Optional[dict]:
        """Return cached result if fresh, else None."""
        key = self._make_key(argument, skill, age)
        with self._conn() as conn:
            row = conn.execute(
                "SELECT result_json, created_at FROM cache WHERE cache_key=?",
                (key,)
            ).fetchone()
            if not row:
                return None

            # Check TTL
            created = datetime.fromisoformat(row["created_at"])
            age_hours = (datetime.now(timezone.utc) - created).total_seconds() / 3600
            if age_hours > self.ttl_hours:
                conn.execute("DELETE FROM cache WHERE cache_key=?", (key,))
                return None

            # Increment hit counter
            conn.execute(
                "UPDATE cache SET hits=hits+1 WHERE cache_key=?", (key,)
            )
        return json.loads(row["result_json"])

    def set(self, argument: str, skill: str, age: int, result: dict):
        key = self._make_key(argument, skill, age)
        with self._conn() as conn:
            conn.execute("""
                INSERT INTO cache(cache_key, result_json, created_at)
                VALUES(?,?,?)
                ON CONFLICT(cache_key) DO UPDATE SET
                    result_json=excluded.result_json,
                    created_at=excluded.created_at
            """, (key, json.dumps(result, default=str),
                  datetime.now(timezone.utc).isoformat()))

    def stats(self) -> dict:
        with self._conn() as conn:
            row = conn.execute("""
                SELECT COUNT(*) as total_entries,
                       SUM(hits) as total_hits,
                       AVG(hits) as avg_hits
                FROM cache
            """).fetchone()
        return dict(row) if row else {}

    # ── Rate limiter ───────────────────────────────────────────────────────────
    def check_rate_limit(self, user_id: str,
                         max_per_minute: int = 10) -> tuple[bool, int]:
        """
        Returns (allowed: bool, remaining: int).
        Uses sliding 60-second window.
        """
        now     = datetime.now(timezone.utc)
        window  = now.strftime("%Y-%m-%dT%H:%M")  # 1-minute window key

        with self._conn() as conn:
            # Clean old windows
            conn.execute("""
                DELETE FROM rate_limits
                WHERE window_start < datetime('now', '-2 minutes')
            """)

            row = conn.execute("""
                SELECT count FROM rate_limits
                WHERE user_id=? AND window_start=?
            """, (user_id, window)).fetchone()

            current = row["count"] if row else 0

            if current >= max_per_minute:
                return False, 0

            # Increment
            conn.execute("""
                INSERT INTO rate_limits(user_id, window_start, count)
                VALUES(?,?,1)
                ON CONFLICT(user_id, window_start) DO UPDATE SET count=count+1
            """, (user_id, window))

        remaining = max_per_minute - current - 1
        return True, remaining