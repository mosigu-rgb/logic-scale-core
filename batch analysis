def build_prompt(arg_data: dict) -> str:
    age = arg_data["age"]
    skill = arg_data["skill"]
    expected = {"beginner": 2.0, "intermediate": 2.8, "advanced": 3.5, "expert": 4.2}[skill]
    vocab = "elementary" if age < 14 else "secondary" if age < 18 else "university"

    return f"""ARGUMENT #{arg_data['id']} — {arg_data['profile']} — Topic: {arg_data['topic']}
TEXT: "{arg_data['argument']}"
USER: age={age}, skill={skill}, job={arg_data['job']}, region={arg_data['region']}
EXPECTED_SCORE_FOR_SKILL: {expected}

Return this exact JSON:
{{
  "id": {arg_data['id']},
  "profile": "{arg_data['profile']}",
  "logic_score": <float>,
  "score_breakdown": {{
    "base": 2.5,
