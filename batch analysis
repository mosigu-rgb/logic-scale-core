def call_claude(settings: dict, system: str, user: str) -> dict:
    import anthropic
    client = anthropic.Anthropic(api_key=settings["anthropic_api_key"])
    response = client.messages.create(
        model=settings.get("model", "claude-sonnet-4-20250514"),
        max_tokens=1500,
        system=system,
        messages=[{"role": "user", "content": user}],
    )
    raw = response.content[0].text.strip()
    import re
    raw = re.sub(r'^```(?:json)?\s*', '', raw)
    raw = re.sub(r'\s*```$', '', raw)
    return json.loads(raw)


def run_batch(settings: dict) -> list:
    results = []
    for arg_data in ARGUMENTS:
        print(f"  Analyzing #{arg_data['id']}: {arg_data['profile']}...", end=" ", flush=True)
        try:
            result = call_claude(settings, SYSTEM_PROMPT, build_prompt(arg_data))
            results.append(result)
            score = result.get("logic_score", 0)
            quality = result.get("argument_quality", "?")
            fallacy_count = len(result.get("fallacies", []))
            print(f"score={score:.2f} | {quality} | {fallacy_count} fallacies")
        except Exception as e:
            print(f"ERROR: {e}")
            results.append({"id": arg_data["id"], "error": str(e)})
        import time; time.sleep(0.8)
    return results


