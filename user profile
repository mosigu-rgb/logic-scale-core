def xp_to_rank(xp: int) -> str:
    rank = "Novice"
    for threshold, name in RANKS:
        if xp >= threshold:
            rank = name
    return rank


class UserProfileDB:
    """Persistent user profiles with cognitive fingerprinting."""

    def __init__(self, db_path: Path):
        db_path.parent.mkdir(parents=True, exist_ok=True)
        self.path = str(db_path)
        self._init()

    def _conn(self):
        conn = sqlite3.connect(self.path)
        conn.row_factory = sqlite3.Row
        return conn

    def _init(self):
        with self._conn() as conn:
            conn.executescript("""
            CREATE TABLE IF NOT EXISTS profiles (
                user_id      TEXT PRIMARY KEY,
                display_name TEXT,
                created_at   TEXT,
                profile_json TEXT NOT NULL,
                updated_at   TEXT
            );
            CREATE TABLE IF NOT EXISTS argument_events (
                id           INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id      TEXT,
                session_id   TEXT,
                timestamp    TEXT,
                topic        TEXT,
                argument_len INTEGER,
                logic_score  REAL,
                weight_delta REAL,
                fallacy_count INTEGER,
                top_fallacy  TEXT,
                argument_style TEXT,
                hour_of_day  INTEGER,
                full_json    TEXT
            );
            CREATE INDEX IF NOT EXISTS idx_ae_user   ON argument_events(user_id);
            CREATE INDEX IF NOT EXISTS idx_ae_topic  ON argument_events(topic);
            CREATE INDEX IF NOT EXISTS idx_ae_score  ON argument_events(logic_score);
            """)

    # ── CRUD ──────────────────────────────────────────────────────────────────
    def get_or_create(self, user_id: str, **kwargs) -> dict:
        with self._conn() as conn:
            row = conn.execute(
                "SELECT profile_json FROM profiles WHERE user_id=?", (user_id,)
            ).fetchone()
        if row:
            return json.loads(row["profile_json"])
        # Create new
        profile = {**DEFAULT_PROFILE, "user_id": user_id,
                   "created_at": datetime.now(timezone.utc).isoformat()}
        profile.update(kwargs)
        self.save(profile)
        return profile

    def save(self, profile: dict):
        profile["updated_at"] = datetime.now(timezone.utc).isoformat()
        with self._conn() as conn:
            conn.execute("""
                INSERT INTO profiles(user_id,display_name,created_at,profile_json,updated_at)
                VALUES(?,?,?,?,?)
                ON CONFLICT(user_id) DO UPDATE SET
                    profile_json=excluded.profile_json,
                    updated_at=excluded.updated_at
            """, (
                profile["user_id"],
                profile.get("display_name","Debater"),
                profile.get("created_at",""),
                json.dumps(profile),
                profile["updated_at"],
            ))

    def record_argument(self, user_id: str, session_id: str,
                        analysis_result: dict, topic: str = "general"):
        """Log one argument event for longitudinal analysis."""
        a   = analysis_result.get("analysis", {})
        arg = analysis_result.get("_raw_argument", "")
        fallacies = a.get("fallacies", [])
        top_f = fallacies[0]["type"] if fallacies else None
        now = datetime.now(timezone.utc)

        with self._conn() as conn:
            conn.execute("""
                INSERT INTO argument_events
                (user_id,session_id,timestamp,topic,argument_len,logic_score,
                 weight_delta,fallacy_count,top_fallacy,argument_style,hour_of_day,full_json)
                VALUES(?,?,?,?,?,?,?,?,?,?,?,?)
            """, (
                user_id, session_id,
                now.isoformat(), topic,
                len(arg.split()),
                float(a.get("logic_score", 0)),
                float(a.get("weight_delta", 0)),
                len(fallacies), top_f,
                self._detect_style(arg),
                now.hour,
                json.dumps(analysis_result, default=str),
            ))

    # ── Profile updater ────────────────────────────────────────────────────────
    def update_after_session(self, user_id: str, session_results: list,
                             topic: str = "general") -> dict:
        """
        Called after each session. Updates all cognitive metrics.
        session_results: list of analysis_result dicts from this session.
        """
        profile = self.get_or_create(user_id)
        if not session_results:
            return profile

        scores = [r["analysis"]["logic_score"] for r in session_results
                  if "analysis" in r]
        if not scores:
            return profile

        avg_score   = sum(scores) / len(scores)
        all_fallacies = []
        for r in session_results:
            all_fallacies.extend(r.get("analysis", {}).get("fallacies", []))

        # ── Score history & velocity ──
        history = profile["score_history"]
        history.append(round(avg_score, 3))
        if len(history) > 100:
            history = history[-100:]
        profile["score_history"] = history

        if len(history) >= 2:
            velocity = sum(
                history[i] - history[i-1]
                for i in range(max(1, len(history)-5), len(history))
            ) / min(5, len(history)-1)
            profile["cognitive"]["improvement_velocity"] = round(velocity, 4)

        # ── Fallacy map ──
        for f in all_fallacies:
            ftype = f.get("type", "unknown")
            profile["weakness_map"][ftype] = profile["weakness_map"].get(ftype, 0) + 1
            profile["fallacy_history"].append({
                "type": ftype, "session": profile["total_sessions"],
                "date": datetime.now(timezone.utc).isoformat()[:10]
            })
        if len(profile["fallacy_history"]) > 500:
            profile["fallacy_history"] = profile["fallacy_history"][-500:]

        # ── Dominant fallacy ──
        wm = profile["weakness_map"]
        if wm:
            profile["cognitive"]["dominant_fallacy"] = max(wm, key=wm.get)
            total_args = max(profile["total_arguments"] + len(scores), 1)
            profile["cognitive"]["fallacy_frequency"] = round(
                sum(wm.values()) / total_args, 2)

        # ── Topic performance ──
        ts = profile["topic_scores"]
        if topic not in ts:
            ts[topic] = avg_score
        else:
            ts[topic] = round((ts[topic] * 0.7) + (avg_score * 0.3), 3)  # EMA
        profile["topic_scores"] = ts

        # ── Consistency score ──
        if len(scores) >= 2:
            import statistics
            std = statistics.stdev(scores)
            profile["cognitive"]["consistency_score"] = round(max(0, 1 - std/2), 3)

        # ── Argument style ──
        styles = [self._detect_style(r.get("_raw_argument",""))
                  for r in session_results]
        if styles:
            profile["cognitive"]["argument_style"] = max(
                set(styles), key=styles.count)

        # ── Avg argument length ──
        lengths = [len(r.get("_raw_argument","").split()) for r in session_results]
        if lengths:
            profile["cognitive"]["avg_argument_length"] = int(sum(lengths)/len(lengths))

        # ── Peak time ──
        hour = datetime.now(timezone.utc).hour
        profile["cognitive"]["peak_performance_time"] = (
            "morning" if hour < 12 else "afternoon" if hour < 17 else "evening"
        )

        # ── XP & rank ──
        profile["total_sessions"]  += 1
        profile["total_arguments"] += len(scores)
        profile["xp"] += XP_PER_SESSION + len(scores) * XP_PER_ARGUMENT
        profile["rank"] = xp_to_rank(profile["xp"])
        profile["last_active"] = datetime.now(timezone.utc).isoformat()

        # ── Skill auto-upgrade ──
        if avg_score >= 4.0 and profile["skill_level"] == "intermediate":
            profile["skill_level"] = "advanced"
        elif avg_score >= 3.0 and profile["skill_level"] == "beginner":
            profile["skill_level"] = "intermediate"

        self.save(profile)
        return profile

    def get_percentile(self, user_id: str, db: "AnalysisDB") -> dict:
        """Compare user to peers (same age group, same region)."""
        profile = self.get_or_create(user_id)
        if not profile["score_history"]:
            return {"percentile": None, "message": "Not enough data yet"}

        user_avg = sum(profile["score_history"][-10:]) / min(10, len(profile["score_history"]))
        ag = profile.get("age_group", "unknown")
        region = profile.get("region", "unknown")

        with self._conn() as conn:
            # Compare to same age group
            peer_scores = conn.execute("""
                SELECT AVG(logic_score) as avg_s
                FROM argument_events ae
                JOIN profiles p ON ae.user_id = p.user_id
                WHERE ae.user_id != ?
                GROUP BY ae.user_id
            """, (user_id,)).fetchall()

        scores = [r["avg_s"] for r in peer_scores if r["avg_s"]]
        if not scores:
            return {"percentile": None, "message": "Not enough peer data yet"}

        below = sum(1 for s in scores if s < user_avg)
        percentile = int(below / len(scores) * 100)
        return {
            "user_avg":    round(user_avg, 2),
            "percentile":  percentile,
            "peer_count":  len(scores),
            "message": f"You are in the {percentile}th percentile among {len(scores)} peers"
        }

