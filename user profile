    # ── Insight generator ──────────────────────────────────────────────────────
    def personal_insights(self, user_id: str) -> List[str]:
        profile = self.get_or_create(user_id)
        cog = profile.get("cognitive", {})
        ts  = profile.get("topic_scores", {})
        insights = []

        # Improvement velocity
        v = cog.get("improvement_velocity", 0)
        if v > 0.1:
            insights.append(f"You are improving rapidly (+{v:.2f}/session) — keep the momentum.")
        elif v < -0.05:
            insights.append("Your scores have been declining slightly. Consider a Weakness Drill session.")

        # Topic gap
        if len(ts) >= 2:
            best_t  = max(ts, key=ts.get)
            worst_t = min(ts, key=ts.get)
            if ts[best_t] - ts[worst_t] > 1.0:
                insights.append(
                    f"Large topic gap: strong in '{best_t}' ({ts[best_t]:.2f}) "
                    f"but weak in '{worst_t}' ({ts[worst_t]:.2f}). "
                    f"This suggests a knowledge gap, not a reasoning flaw."
                )

        # Peak time
        peak = cog.get("peak_performance_time")
        if peak:
            insights.append(f"Your arguments are strongest in the {peak}.")

        # Dominant fallacy
        df = cog.get("dominant_fallacy")
        if df:
            insights.append(
                f"Your most frequent fallacy is '{df.replace('_',' ')}' "
                f"({profile['weakness_map'].get(df,0)} occurrences). "
                f"Prioritize the Weakness Drill for this."
            )

        # Style
        style = cog.get("argument_style")
        if style:
            tips = {
                "narrative":   "You argue narratively — powerful for persuasion but add more data.",
                "analytical":  "You argue analytically — very strong, try adding emotional resonance.",
                "data_driven": "You use data well — make sure your data sources are robust.",
                "emotional":   "You rely on emotion — try the 'evidence-first' drill.",
                "socratic":    "You ask good questions — practice making direct claims too.",
            }
            insights.append(tips.get(style, ""))

        return [i for i in insights if i]

    @staticmethod
    def _detect_style(text: str) -> str:
        """Heuristic argument style detection."""
        text_lower = text.lower()
        data_words  = ["study", "research", "data", "statistic", "%", "survey",
                       "according to", "shows that", "evidence"]
        emotion_words = ["feel", "believe", "unfair", "terrible", "wonderful",
                         "everyone knows", "obvious", "clearly"]
        question_words = ["why", "how", "what if", "consider", "isn't it"]

        data_count     = sum(1 for w in data_words     if w in text_lower)
        emotion_count  = sum(1 for w in emotion_words  if w in text_lower)
        question_count = sum(1 for w in question_words if w in text_lower)

        if data_count >= 2:     return "data_driven"
        if question_count >= 2: return "socratic"
        if emotion_count >= 2:  return "emotional"
        if len(text.split()) > 60: return "analytical"
        return "narrative"